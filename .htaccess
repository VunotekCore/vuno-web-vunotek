RewriteEngine On

# Blog SSR fallback: /blog/{slug} → /blog/index.php (only if no static HTML exists)
RewriteCond %{DOCUMENT_ROOT}/blog/$1/index.html !-f
RewriteCond %{DOCUMENT_ROOT}/blog/$1.html !-f
RewriteCond %{DOCUMENT_ROOT}/$1 !-f
RewriteRule ^blog/([a-z0-9_-]+)/?$ /blog/index.php?slug=$1 [L,QSA]

# EN blog: /en/blog/{slug} → /blog/index.php?slug={slug}&locale=en
RewriteCond %{DOCUMENT_ROOT}/en/blog/$1/index.html !-f
RewriteCond %{DOCUMENT_ROOT}/en/blog/$1.html !-f
RewriteRule ^en/blog/([a-z0-9_-]+)/?$ /blog/index.php?slug=$1&locale=en [L,QSA]
