# ImageKit CDN configuration
# Get your endpoint from ImageKit dashboard -> https://ik.imagekit.io/{your_account_id}/
PUBLIC_IMAGEKIT_ENDPOINT=https://ik.imagekit.io/your_account_id/

# Site URL (used for sitemap, canonical, etc)
PUBLIC_SITE_URL=http://localhost:4321

# PHP API Base URL (optional — defaults to vunotek.com in production)
# Dev always uses http://localhost:8000 (serve api/ folder)
# PUBLIC_API_URL=https://api.ejemplo.com

# Google Analytics 4 Measurement ID
# Get it from https://analytics.google.com -> Admin -> Data Streams -> Web
# Format: G-XXXXXXXXXX
PUBLIC_GA_ID=
