---
import ScrollReveal from './ScrollReveal.astro'

export interface Props {
  title: string
  items: Array<{ icon: string; name: string }>
}

const { title, items } = Astro.props
---

<ScrollReveal>
  <div class="text-center">
    <h2 class="font-headline-md text-headline-md text-slate-text mb-lg">{title}</h2>
    <div class="flex flex-wrap justify-center items-center gap-xl opacity-60 hover:opacity-100 transition-opacity">
      {items.map((item) => (
        <div class="flex items-center gap-sm">
          <span class="material-symbols-outlined text-vue-green text-4xl">{item.icon}</span>
          <span class="font-display-lg text-headline-md font-bold">{item.name}</span>
        </div>
      ))}
    </div>
  </div>
</ScrollReveal>
