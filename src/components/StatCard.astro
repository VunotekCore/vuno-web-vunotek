---
export interface Props {
  value: string;
  label: string;
}
---

<dl class="text-center">
  <dd class="text-headline-lg md:text-display-lg-mobile font-display-lg text-electric-blue mb-xs metric-glow">
    {Astro.props.value}
  </dd>
  <dt class="font-label-mono text-label-mono text-slate-text uppercase tracking-widest">
    {Astro.props.label}
  </dt>
</dl>
