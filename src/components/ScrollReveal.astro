---
export interface Props {
  class?: string;
  delay?: number;
  stagger?: boolean;
}
const { delay = 0, stagger = false } = Astro.props;
---

<div
  class:list={[
    'transition-all duration-700',
    stagger ? '' : 'opacity-0 translate-y-16',
    Astro.props.class,
  ]}
  style={`transition-delay: ${delay}ms;`}
  data-scroll-reveal
>
  <slot />
</div>
