---
const currentLocale = Astro.currentLocale || 'es';
const targetLocale = currentLocale === 'es' ? 'en' : 'es';
const targetLabel = currentLocale === 'es' ? 'EN' : 'ES';
const currentUrl = Astro.url.pathname;
const targetUrl = targetLocale === 'en' ? `/en${currentUrl === '/' ? '' : currentUrl}` : currentUrl.replace(/^\/en/, '') || '/';
---

<a
  href={targetUrl}
  class="inline-flex items-center gap-1.5 font-label-mono text-label-mono text-on-surface-variant hover:text-vue-green transition-colors px-2 py-1 ml-4"
  aria-label={`Switch to ${targetLabel}`}
>
  {
    targetLocale === 'en'
      ? <svg width="16" height="12" viewBox="0 0 16 12" class="shrink-0"><rect width="16" height="12" rx="1" fill="#012169"/><rect x="6" width="4" height="12" fill="#fff"/><rect y="4" width="16" height="4" fill="#fff"/><rect x="7" width="2" height="12" fill="#c8102e"/><rect y="5" width="16" height="2" fill="#c8102e"/><path d="M0 0l8 6M16 0L8 6M0 12l8-6M16 12l8-6" stroke="#fff" stroke-width="2.5" fill="none"/><path d="M0 0l8 6M16 0L8 6M0 12l8-6M16 12l8-6" stroke="#c8102e" stroke-width="1.2" fill="none"/></svg>
      : <svg width="16" height="12" viewBox="0 0 16 12" class="shrink-0"><rect width="16" height="12" rx="1" fill="#c60b1e"/><rect y="3" width="16" height="6" fill="#ffc400"/></svg>
  }
  {targetLabel}
</a>
