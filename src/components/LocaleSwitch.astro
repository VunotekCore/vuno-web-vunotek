---
const currentLocale = Astro.currentLocale || 'es';
const targetLocale = currentLocale === 'es' ? 'en' : 'es';
const targetLabel = currentLocale === 'es' ? 'EN' : 'ES';
const currentUrl = Astro.url.pathname;
const blogPostMatch = currentUrl.match(/^\/(en\/)?blog\/(.+)$/);
let targetUrl: string;
if (blogPostMatch) {
  const hasEnPrefix = !!blogPostMatch[1]
  const blogSlug = blogPostMatch[2].replace(/\/$/, '')
  if (hasEnPrefix) {
    targetUrl = `/blog/${blogSlug.replace(/-en$/, '')}/`
  } else {
    targetUrl = `/en/blog/${blogSlug}-en/`
  }
} else {
  targetUrl = targetLocale === 'en' ? `/en${currentUrl === '/' ? '' : currentUrl}` : currentUrl.replace(/^\/en/, '') || '/';
}
---

<a
  href={targetUrl}
  class="inline-flex items-center gap-1.5 font-label-mono text-label-mono text-on-surface-variant hover:text-vue-green transition-colors px-2 py-1 ml-4"
  aria-label={`Switch to ${targetLabel}`}
  onclick="localStorage.setItem('locale', '{targetLocale}')"
>
  {
    targetLocale === 'en'
      ? <svg width="16" height="12" viewBox="0 0 16 12" class="shrink-0"><rect width="16" height="12" rx="1" fill="#fff"/><rect y="0" width="16" height="1" fill="#b22234"/><rect y="2" width="16" height="1" fill="#b22234"/><rect y="4" width="16" height="1" fill="#b22234"/><rect y="6" width="16" height="1" fill="#b22234"/><rect y="8" width="16" height="1" fill="#b22234"/><rect y="10" width="16" height="1" fill="#b22234"/><rect width="7" height="6" fill="#3c3b6e"/></svg>
      : <svg width="16" height="12" viewBox="0 0 16 12" class="shrink-0"><rect width="16" height="12" rx="1" fill="#c60b1e"/><rect y="3" width="16" height="6" fill="#ffc400"/></svg>
  }
  {targetLabel}
</a>
