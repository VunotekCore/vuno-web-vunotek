---
import ScrollReveal from './ScrollReveal.astro'

export interface Props {
  anchor: string
  title: string
  subtitle: string
  items: Array<{
    id: string
    step: string
    title: string
    description: string
  }>
}

const { anchor, title, subtitle, items } = Astro.props
---

<div class="flex flex-col gap-lg">
  <ScrollReveal>
    <div class="flex flex-col gap-base">
      <span
        class="inline-flex items-center gap-sm bg-electric-blue/10 border border-electric-blue/20 w-fit px-4 py-1 rounded-full font-label-mono text-label-mono text-electric-blue tracking-wider uppercase"
      >
        <span class="w-1.5 h-1.5 rounded-full bg-electric-blue"></span>
        {anchor}
      </span>
      <h2 class="font-display-lg text-headline-lg-mobile md:text-headline-lg">
        {title}
      </h2>
      <p class="font-body-lg text-body-lg max-sm:text-body-md text-slate-text max-w-2xl">
        {subtitle}
      </p>
    </div>
  </ScrollReveal>

  <!-- Desktop: Horizontal pipeline (≥1190px) -->
  <div class="relative hidden min-[1190px]:block">
    <div class="absolute left-[calc(16.66%+1.75rem)] right-[calc(16.66%+1.75rem)] top-[7px] h-0.5 bg-gradient-to-r from-electric-blue/30 via-electric-blue/50 to-electric-blue/30"></div>

    <div class="relative grid grid-cols-3 gap-8">
      {items.map((item, i) => (
        <div class="relative flex flex-col items-center">
          <div
            class="anim-dot w-4 h-4 rounded-full bg-electric-blue ring-[4px] ring-surface-container-lowest z-10"
            style={`animation-delay: ${i * 3}s`}
          ></div>

          {i < items.length - 1 && (
            <div
              class="absolute top-[-2px] -right-[26px] z-20 anim-chevron"
              style={`animation-delay: ${i * 3}s`}
            >
              <svg class="w-5 h-5" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <path
                  d="M6 4l4 4-4 4"
                  stroke="currentColor"
                  stroke-width="2.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                />
              </svg>
            </div>
          )}

          <article class="philosophy-card w-full mt-3 bg-surface-container border border-outline-variant/10 rounded-xl max-sm:p-md p-lg flex flex-col gap-base">
            <span class="font-label-mono text-label-mono text-electric-blue/70 tracking-wider">
              {item.step}
            </span>
            <h3 class="font-display-lg text-headline-md text-on-surface">
              {item.title}
            </h3>
            <p class="font-body-md text-body-md text-slate-text">
              {item.description}
            </p>
          </article>
        </div>
      ))}
    </div>
  </div>

  <!-- Mobile: Vertical timeline (<1190px) -->
  <div class="flex flex-col min-[1190px]:hidden">
    {items.map((item, i) => (
      <ScrollReveal delay={i * 100}>
        <div class="relative flex gap-lg max-sm:pl-md pl-lg max-sm:pb-lg pb-xl last:pb-0">
          <div class="flex flex-col items-center">
            <div class="w-3.5 h-3.5 rounded-full bg-electric-blue ring-[3px] ring-surface-container-lowest flex-shrink-0 z-10"></div>
            {i < items.length - 1 && (
              <div class="w-0.5 flex-1 bg-electric-blue/30 mt-1"></div>
            )}
          </div>
          <div class="flex flex-col gap-sm min-w-0">
            <span class="font-label-mono text-label-mono text-electric-blue/70 tracking-wider">
              {item.step}
            </span>
            <h3 class="font-display-lg text-headline-md text-on-surface">
              {item.title}
            </h3>
            <p class="font-body-md text-body-md text-slate-text">
              {item.description}
            </p>
          </div>
        </div>
      </ScrollReveal>
    ))}
  </div>
</div>

<style>
  @keyframes dot-glow {
    0%, 22% {
      box-shadow: 0 0 0 6px var(--color-electric-blue), 0 0 24px color-mix(in srgb, var(--color-electric-blue) 40%, transparent);
      transform: scale(1.4);
    }
    28%, 100% {
      box-shadow: 0 0 0 4px var(--color-surface-container-lowest);
      transform: scale(1);
    }
  }

  @keyframes chevron-glow {
    0%, 22% {
      opacity: 1;
      color: var(--color-electric-blue);
    }
    28%, 100% {
      opacity: 0.15;
    }
  }

  .anim-dot {
    animation: dot-glow 9s infinite;
  }

  .anim-chevron {
    animation: chevron-glow 9s infinite;
  }

  .philosophy-card:hover {
    border-color: var(--color-electric-blue) !important;
    box-shadow: 0 0 24px color-mix(in srgb, var(--color-electric-blue) 12%, transparent);
  }
</style>
