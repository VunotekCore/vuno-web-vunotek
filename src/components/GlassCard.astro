---
export interface Props {
  class?: string;
  hover?: boolean;
}
---

<div
  class:list={[
    'glass-panel rounded-xl relative overflow-hidden transition-all duration-300',
    Astro.props.hover !== false && 'hover:border-electric-blue/50',
    Astro.props.class,
  ]}
  style="--mouse-x: 50%; --mouse-y: 50%;"
  data-glass-card
>
  <div
    class="pointer-events-none absolute -inset-px rounded-xl opacity-0 transition-opacity duration-300"
    style="background: radial-gradient(600px circle at var(--mouse-x, 50%) var(--mouse-y, 50%), rgba(0,168,255,0.08), transparent 60%);"
    data-glass-glow
  />
  <div class="relative z-10">
    <slot />
  </div>
</div>

<script>
  let rafId = 0;
  let pendingCard: HTMLElement | null = null;
  let pendingX = 0;
  let pendingY = 0;

  function flush() {
    rafId = 0;
    if (!pendingCard) return;
    const rect = pendingCard.getBoundingClientRect();
    pendingCard.style.setProperty('--mouse-x', `${((pendingX - rect.left) / rect.width) * 100}%`);
    pendingCard.style.setProperty('--mouse-y', `${((pendingY - rect.top) / rect.height) * 100}%`);
    const glow = pendingCard.querySelector('[data-glass-glow]') as HTMLElement;
    if (glow) glow.style.opacity = '1';
    pendingCard = null;
  }

  document.addEventListener('pointermove', (e: PointerEvent) => {
    if (!(e.target instanceof Element)) return
    const card = e.target.closest('[data-glass-card]') as HTMLElement | null;
    if (!card) return;
    pendingCard = card;
    pendingX = e.clientX;
    pendingY = e.clientY;
    if (!rafId) rafId = requestAnimationFrame(flush);
  });
  document.addEventListener('pointerleave', (e: PointerEvent) => {
    if (!(e.target instanceof Element)) return
    const card = e.target.closest('[data-glass-card]') as HTMLElement | null;
    if (!card) return;
    const glow = card.querySelector('[data-glass-glow]') as HTMLElement;
    if (glow) glow.style.opacity = '0';
  }, true);
</script>
