---
export interface Props {
  name: string;
  role: string;
  initials: string;
}
---

<div class="glass-panel p-lg rounded-xl text-center group hover:border-electric-blue/50 transition-all duration-300">
  <div class="w-20 h-20 rounded-full bg-electric-blue/20 mx-auto mb-md flex items-center justify-center">
    <span class="font-display-lg text-headline-lg text-electric-blue">{Astro.props.initials}</span>
  </div>
  <h3 class="font-headline-md text-headline-md text-on-surface mb-xs">{Astro.props.name}</h3>
  <p class="font-label-mono text-label-mono text-slate-text">{Astro.props.role}</p>
</div>
