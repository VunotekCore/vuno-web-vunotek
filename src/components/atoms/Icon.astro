---
import { icons } from 'lucide'
import { ICON_MAP } from '../../lib/icon-map'

export interface Props {
  name: string
  size?: number
  class?: string
  strokeWidth?: number
}

const { name, size = 24, class: className = '', strokeWidth = 2 } = Astro.props

const lucideName = (ICON_MAP as Record<string, string>)[name] || name
const iconNode = (icons as Record<string, any>)[lucideName]

function renderNode(node: any[]): string {
  const [tag, attrs, children] = node
  const attrStr = Object.entries(attrs || {})
    .map(([k, v]) => `${k}="${String(v).replace(/"/g, '&quot;')}"`)
    .join(' ')
  const inner = children ? (children as any[]).map((c) => renderNode(c)).join('') : ''
  return `<${tag} ${attrStr}>${inner}</${tag}>`
}

let svg = ''
if (iconNode) {
  const inner = (iconNode as any[]).map((n: any[]) => renderNode(n)).join('')
  svg =
    '<svg xmlns="http://www.w3.org/2000/svg" width="' +
    size +
    '" height="' +
    size +
    '" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="' +
    strokeWidth +
    '" stroke-linecap="round" stroke-linejoin="round">' +
    inner +
    '</svg>'
}
---
{svg ? (
  <span set:html={svg} class={className} aria-hidden="true" />
) : (
  <span class={className} aria-hidden="true">?</span>
)}
