---
import GlassCard from './GlassCard.astro';

export interface Props {
  title: string;
}
const { title } = Astro.props;
---

<GlassCard class="p-md">
  <h3 class="font-headline-md text-headline-md max-sm:text-headline-sm text-on-surface mb-sm flex items-center gap-base">
    <span class="material-symbols-outlined text-vue-green">terminal</span>
    {title}
  </h3>
  <div class="flex flex-col gap-sm">
    <a class="flex items-center justify-between p-sm bg-surface-dim rounded-lg group hover:bg-surface-variant transition-all" href="https://github.com/" target="_blank" rel="noopener noreferrer">
      <div class="flex items-center gap-md">
        <span class="material-symbols-outlined text-slate-text group-hover:text-vue-green">code</span>
        <span class="font-body-md text-on-surface">GitHub</span>
      </div>
      <span class="material-symbols-outlined text-slate-text group-hover:translate-x-1 transition-transform">arrow_forward</span>
    </a>
    <a class="flex items-center justify-between p-sm bg-surface-dim rounded-lg group hover:bg-surface-variant transition-all" href="https://linkedin.com/" target="_blank" rel="noopener noreferrer">
      <div class="flex items-center gap-md">
        <span class="material-symbols-outlined text-slate-text group-hover:text-vue-green">share</span>
        <span class="font-body-md text-on-surface">LinkedIn</span>
      </div>
      <span class="material-symbols-outlined text-slate-text group-hover:translate-x-1 transition-transform">arrow_forward</span>
    </a>
    <a class="flex items-center justify-between p-sm bg-surface-dim rounded-lg group hover:bg-surface-variant transition-all" href="https://facebook.com/" target="_blank" rel="noopener noreferrer">
      <div class="flex items-center gap-md">
        <span class="material-symbols-outlined text-slate-text group-hover:text-vue-green">groups</span>
        <span class="font-body-md text-on-surface">Facebook</span>
      </div>
      <span class="material-symbols-outlined text-slate-text group-hover:translate-x-1 transition-transform">arrow_forward</span>
    </a>
  </div>
</GlassCard>

<style>
  .material-symbols-outlined {
    font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
  }
</style>
