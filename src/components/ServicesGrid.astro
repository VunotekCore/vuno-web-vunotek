---
import GlassCard from './GlassCard.astro'
import ScrollReveal from './ScrollReveal.astro'
import Icon from './Icon.astro';

export interface Props {
  anchor: string
  title: string
  titleAccent?: string
  titleRest?: string
  subtitle: string
  items: Array<{
    id: string
    title: string
    description: string
    tech: string[]
  }>
}

const { anchor, title, titleAccent, titleRest = '', subtitle, items } = Astro.props

const iconMap: Record<string, string> = {
  'backend-engineering': 'terminal',
  'crm-architecture': 'cloud_done',
  'fullstack-platforms': 'view_quilt',
}
---

<div class="flex flex-col gap-lg">
  <ScrollReveal>
    <div class="flex flex-col gap-base">
      <span class="inline-flex items-center gap-sm bg-electric-blue/10 border border-electric-blue/20 w-fit px-4 py-1 rounded-full font-label-mono text-label-mono text-electric-blue tracking-wider uppercase">
        <span class="w-1.5 h-1.5 rounded-full bg-electric-blue"></span>
        {anchor}
      </span>
      <h2 class="font-display-lg text-headline-lg-mobile md:text-headline-lg">
        {title}
        {titleAccent && (
          <span class="bg-gradient-to-r from-electric-blue to-sky-400 bg-clip-text text-transparent">
            {titleAccent}
          </span>
        )}
        {titleRest}
      </h2>
      <p class="font-body-lg text-body-lg max-sm:text-body-md text-slate-text max-w-2xl">{subtitle}</p>
    </div>
  </ScrollReveal>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-md">
    {items.map((item, i) => (
      <ScrollReveal delay={i * 100} stagger>
        <GlassCard class="max-sm:p-md p-lg flex flex-col gap-md h-full">
          <Icon name={iconMap[item.id] || 'code'} class="text-electric-blue text-5xl" />
          <h3 class="font-display-lg text-headline-md">{item.title}</h3>
          <p class="font-body-md text-slate-text">{item.description}</p>
          <div class="flex flex-wrap gap-sm mt-auto pt-md">
            {item.tech.map((t) => (
              <span class="font-label-mono text-label-mono text-electric-blue bg-electric-blue/10 border border-electric-blue/20 px-2.5 py-0.5 rounded-md">
                {t}
              </span>
            ))}
          </div>
        </GlassCard>
      </ScrollReveal>
    ))}
  </div>
</div>
