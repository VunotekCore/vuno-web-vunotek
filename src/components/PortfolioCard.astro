---
import Icon from './Icon.astro';
export interface Props {
  tag: string
  title: string
  description: string
  image: string | undefined
  slug: string | undefined
  locale?: string
  srcset?: string
  sizes?: string
}

const { tag, title, description, image, slug, locale = 'es', srcset, sizes } = Astro.props
const href = slug
  ? locale === 'en'
    ? `/en/proyectos/${slug}`
    : `/proyectos/${slug}`
  : undefined
const isPlaceholder = !image
---

{
  href ? (
    <a href={href} class="group block cursor-pointer no-underline">
      <div class="aspect-video overflow-hidden rounded-xl mb-md border border-outline-variant/30 transition-all duration-300 group-hover:border-electric-blue/50">
        {isPlaceholder ? (
          <div class="w-full h-full bg-surface-charcoal flex items-center justify-center">
            <div class="flex flex-col items-center gap-sm opacity-40">
              <Icon name="image" class="text-5xl text-slate-text" />
              <span class="font-label-mono text-label-mono text-slate-text uppercase">{tag}</span>
            </div>
          </div>
        ) : (
          <img
            src={image!}
            alt=""
            loading="lazy"
            decoding="async"
            width="640"
            height="360"
            srcset={srcset}
            sizes={sizes}
            class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
          />
        )}
      </div>
      <div class="flex items-center gap-2 mb-sm">
        <span class="font-label-mono text-[12px] text-electric-blue bg-electric-blue/10 px-2 py-0.5 rounded uppercase">{tag}</span>
      </div>
      <h4 class="font-headline-md text-headline-md text-on-surface group-hover:text-electric-blue transition-colors mb-xs">{title}</h4>
      <p class="font-body-md text-body-md text-slate-text">{description}</p>
    </a>
  ) : (
    <div class="group">
      <div class="aspect-video overflow-hidden rounded-xl mb-md border border-outline-variant/30 transition-all duration-300">
        {isPlaceholder ? (
          <div class="w-full h-full bg-surface-charcoal flex items-center justify-center">
            <div class="flex flex-col items-center gap-sm opacity-40">
              <Icon name="image" class="text-5xl text-slate-text" />
              <span class="font-label-mono text-label-mono text-slate-text uppercase">{tag}</span>
            </div>
          </div>
        ) : (
          <img
            src={image!}
            alt=""
            loading="lazy"
            decoding="async"
            width="640"
            height="360"
            srcset={srcset}
            sizes={sizes}
            class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
          />
        )}
      </div>
      <div class="flex items-center gap-2 mb-sm">
        <span class="font-label-mono text-[12px] text-electric-blue bg-electric-blue/10 px-2 py-0.5 rounded uppercase">{tag}</span>
      </div>
      <h4 class="font-headline-md text-headline-md text-on-surface transition-colors mb-xs">{title}</h4>
      <p class="font-body-md text-body-md text-slate-text">{description}</p>
    </div>
  )
}


