---
import ScrollIndicator from './ScrollIndicator.astro'
import Icon from './Icon.astro';

export interface Props {
  variant?: 'code' | 'gradient' | 'centered' | 'contact'
  badge?: string
  title: string
  titleAccent?: string
  titleRest?: string
  description: string
  cta?: { label: string; href?: string }
  ctaSecondary?: { label: string; href?: string }
  statLabels?: string[]
  scrollLock?: boolean
}
---

<section class="relative overflow-hidden min-h-dvh flex flex-col" style="scroll-margin-top: 80px;" data-scroll-lock={Astro.props.scrollLock ? '' : undefined}>
  <div class="max-w-[min(90vw,1600px)] mx-auto px-margin flex-1 flex flex-col">
    {
      Astro.props.variant === 'code' && (
        <div class="grid md:grid-cols-2 gap-md md:gap-md items-start md:items-center flex-1 max-sm:pt-24 pt-24 md:pt-24 max-sm:items-stretch">
          <div class="flex flex-col gap-md left-col max-md:hidden">
            {Astro.props.badge && (
              <div class="inline-flex items-center max-sm:gap-xs gap-sm bg-surface-charcoal/50 border border-electric-blue/30 w-fit px-4 py-1.5 rounded-full max-sm:px-3 max-sm:py-1 max-sm:mb-4 sm:max-md:mb-4">
                <span class="w-2 h-2 rounded-full bg-electric-blue animate-pulse shrink-0" aria-hidden="true" />
                <span class="font-label-mono text-label-mono text-electric-blue tracking-wider uppercase max-sm:text-xs max-sm:tracking-normal md:max-lg:text-xs md:max-lg:tracking-normal">
                  {Astro.props.badge}
                </span>
              </div>
            )}
            <h1 class="font-display-lg md:max-lg:text-2xl lg:text-4xl lg:max-[1164px]:text-2xl leading-tight max-sm:text-xl sm:text-2xl max-sm:text-center sm:text-center md:max-lg:text-left lg:text-left max-sm:mb-4 sm:max-md:mb-4">
              {Astro.props.title}{' '}
              <span class="text-electric-blue" id="hero-accent">
                {Astro.props.titleAccent}
              </span>{' '}
              {Astro.props.titleRest}
            </h1>
            <p class="font-body-lg text-body-lg text-slate-text max-w-[36rem] max-sm:text-body-md max-sm:text-center sm:text-center md:max-lg:text-left lg:text-left max-sm:mb-4 sm:max-md:mb-4 md:max-lg:text-body-md lg:max-[1164px]:text-body-md">
              {Astro.props.description}
            </p>
            <div class="flex flex-wrap gap-md mt-sm max-sm:flex-col max-sm:w-full sm:max-md:w-full md:max-lg:flex-col md:max-lg:w-full lg:flex-row">
              {Astro.props.cta && (
                <a
                  href={Astro.props.cta.href || '#'}
                  class="bg-electric-blue text-azure-deep px-8 py-4 rounded-lg font-label-mono text-body-md uppercase hover:shadow-[0_0_20px_rgba(0,168,255,0.4)] transition-all max-sm:w-full max-sm:text-center sm:max-md:flex-1 sm:max-md:text-center md:max-lg:w-full md:max-lg:text-center lg:max-xl:flex-1 lg:max-xl:text-center lg:max-xl:text-sm lg:max-xl:px-2"
                >
                  {Astro.props.cta.label}
                </a>
              )}
              {Astro.props.ctaSecondary && (
                <a
                  href={Astro.props.ctaSecondary.href || '#'}
                  class="border border-electric-blue text-electric-blue px-8 py-4 rounded-lg font-label-mono text-label-mono uppercase hover:bg-electric-blue/10 transition-all max-sm:w-full max-sm:text-center sm:max-md:flex-1 sm:max-md:text-center md:max-lg:w-full md:max-lg:text-center lg:max-xl:flex-1 lg:max-xl:text-center lg:max-xl:text-xs lg:max-xl:px-2"
                >
                  {Astro.props.ctaSecondary.label}
                </a>
              )}
            </div>
          </div>
          <div class="relative">
            <div
              class="glass-panel p-gutter rounded-xl shadow-2xl relative overflow-hidden"
              id="code-panel"
            >
              <div class="flex items-center justify-between mb-md">
                <div class="flex gap-2">
                  <div class="w-3 h-3 rounded-full bg-red-500/50" />
                  <div class="w-3 h-3 rounded-full bg-yellow-500/50" />
                  <div class="w-3 h-3 rounded-full bg-green-500/50" />
                </div>
                <span
                  id="code-lang"
                  class="font-label-mono text-label-mono text-on-surface-variant/50 tracking-wider max-md:hidden"
                >
                  JavaScript
                </span>
                <span
                  id="code-lang-mobile"
                  class="font-label-mono text-label-mono text-on-surface-variant/50 tracking-wider md:hidden"
                >
                  hero.config.ts
                </span>
              </div>
              <div
                id="code-lines"
                class="font-label-mono text-label-mono space-y-2 min-h-[200px] max-md:hidden"
              />
              <div
                id="mobile-code"
                class="font-label-mono text-label-mono space-y-2 min-h-[200px] md:hidden"
              >
                {/* <p class="text-on-secondary-container/50">// ── hero.config.ts ──</p> */}
                {/* <p class="text-on-secondary-container/50">&nbsp;</p> */}
                <p class="text-sky-300">export const hero = &#123;</p>
                <p class="text-cyan-400 ml-4">
                  title:&nbsp;&nbsp;&nbsp;&nbsp;"{Astro.props.title}"
                </p>
                <p class="text-cyan-400 ml-4">
                  accent:&nbsp;&nbsp;"{Astro.props.titleAccent ?? ''}"
                </p>
                <p class="text-cyan-400 ml-4">
                  desc:&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;"{Astro.props.description}"
                </p>
                <p class="text-sky-300">&#125;</p>
                {/* <p class="text-on-secondary-container/50">&nbsp;</p> */}
              </div>
              <div class="flex flex-col gap-md md:hidden mt-md max-sm:flex-row max-sm:gap-sm">
                {Astro.props.cta && (
                  <a
                    href={Astro.props.cta.href || '#'}
                    title={Astro.props.cta.label}
                    class="flex items-center justify-center w-full text-center bg-electric-blue text-azure-deep px-8 py-4 rounded-lg font-label-mono text-body-md uppercase hover:shadow-[0_0_20px_rgba(0,168,255,0.4)] transition-all max-sm:flex-1 max-sm:px-3 max-sm:py-2"
                  >
                    <Icon name="rocket_launch" class="max-sm:text-xl" />
                    <span class="sm:inline hidden">{Astro.props.cta.label}</span>
                  </a>
                )}
                {Astro.props.ctaSecondary && (
                  <a
                    href={Astro.props.ctaSecondary.href || '#'}
                    title={Astro.props.ctaSecondary.label}
                    class="flex items-center justify-center w-full text-center border border-electric-blue text-electric-blue px-8 py-4 rounded-lg font-label-mono text-label-mono uppercase hover:bg-electric-blue/10 transition-all max-sm:flex-1 max-sm:px-3 max-sm:py-2"
                  >
                    <Icon name="code" class="max-sm:text-xl" />
                    <span class="sm:inline hidden">{Astro.props.ctaSecondary.label}</span>
                  </a>
                )}
              </div>
              <div class="absolute -bottom-10 -right-10 w-40 h-40 bg-electric-blue/20 blur-3xl rounded-full" aria-hidden="true" />
            </div>
            <div
              class="absolute -bottom-8 -right-8 glass-panel p-md rounded-lg border-electric-blue/20 max-md:absolute max-md:top-2 max-md:right-2 max-md:bottom-auto max-md:p-2 max-md:bg-surface-container/60"
              id="stats-card"
              data-stat-labels={JSON.stringify(Astro.props.statLabels ?? [])}
            >
              <div class="flex items-center gap-md max-md:gap-1">
                <div class="bg-electric-blue/20 p-2 max-md:p-1 rounded-lg">
                  <Icon name="speed" class="text-electric-blue text-2xl max-md:text-lg" />
                </div>
                <div>
                  <p class="font-display-lg text-headline-md max-md:text-sm text-electric-blue m-0" id="stat-value">
                    99.9%
                  </p>
                  <p class="font-label-mono text-xs max-md:text-[10px] text-slate-text">
                    <span id="stat-label">{Astro.props.statLabels?.[0] ?? 'CORE WEB VITALS'}</span>
                  </p>
                </div>
              </div>
            </div>
          </div>
        </div>
      )
    }

    {
      Astro.props.variant === 'gradient' && (
        <div class="flex-1 flex flex-col justify-start md:justify-center pt-20 md:pt-24 relative">
          <div class="absolute -top-20 -right-20 w-96 h-96 bg-electric-blue/5 rounded-full blur-[100px]" aria-hidden="true" />
          <div class="max-w-3xl">
            <h1 class="font-display-lg text-display-lg mb-md leading-tight">
              {Astro.props.title} <span class="text-gradient">{Astro.props.titleAccent}</span>{' '}
              {Astro.props.titleRest}
            </h1>
            <p class="text-body-lg font-body-lg text-slate-text mb-lg">{Astro.props.description}</p>
            {(Astro.props.cta || Astro.props.ctaSecondary) && (
              <div class="flex flex-wrap gap-md">
                {Astro.props.cta && (
                  <a
                    href={Astro.props.cta.href || '#'}
                    class="bg-electric-blue text-azure-deep px-8 py-4 rounded-lg font-bold hover:brightness-110 transition-all"
                  >
                    {Astro.props.cta.label}
                  </a>
                )}
                {Astro.props.ctaSecondary && (
                  <a
                    href={Astro.props.ctaSecondary.href || '#'}
                    class="border border-electric-blue text-electric-blue px-8 py-4 rounded-lg font-label-mono hover:bg-electric-blue/10 transition-all"
                  >
                    {Astro.props.ctaSecondary.label}
                  </a>
                )}
              </div>
            )}
          </div>
        </div>
      )
    }

    {
      Astro.props.variant === 'centered' && (
        <div class="flex-1 flex items-start justify-start md:items-center md:justify-center bg-surface-container-lowest relative pt-20 md:pt-24">
          <div class="relative z-10 text-center px-margin">
            {Astro.props.badge && (
              <div class="inline-block px-sm py-xs bg-primary-container/30 border border-electric-blue/30 rounded-full mb-md">
                <span class="font-label-mono text-label-mono text-electric-blue uppercase tracking-widest">
                  {Astro.props.badge}
                </span>
              </div>
            )}
            <h1 class="font-display-lg text-display-lg-mobile md:text-display-lg text-on-surface mb-md">
              {Astro.props.title} <span class="text-electric-blue">{Astro.props.titleAccent}</span>{' '}
              {Astro.props.titleRest}
            </h1>
            <p class="font-body-lg text-body-lg text-slate-text max-w-2xl mx-auto">
              {Astro.props.description}
            </p>
          </div>
        </div>
      )
    }

    {
      Astro.props.variant === 'contact' && (
        <div class="flex-1 flex flex-col justify-start md:justify-center pt-20 md:pt-24">
          {Astro.props.badge && (
            <span class="font-label-mono text-label-mono text-electric-blue tracking-widest uppercase mb-base block">
              {Astro.props.badge}
            </span>
          )}
          <h1 class="font-display-lg text-display-lg-mobile md:text-display-lg text-on-surface mb-md">
            {Astro.props.title} <span class="text-electric-blue">{Astro.props.titleAccent}</span>{' '}
            {Astro.props.titleRest}
          </h1>
          <p class="font-body-lg text-body-lg text-slate-text max-w-2xl">
            {Astro.props.description}
          </p>
        </div>
      )
    }

    <div class="flex justify-center pt-8 pb-8">
      <ScrollIndicator />
    </div>
  </div>
</section>

<script>
  const container = document.getElementById('code-lines') as HTMLElement
  const statsCardEl = document.getElementById('stats-card') as HTMLElement
  const statLabels: string[] = statsCardEl?.dataset?.statLabels
    ? JSON.parse(statsCardEl.dataset.statLabels)
    : ['CORE WEB VITALS', 'API LATENCY', 'QUERY TIME', 'QUERY ACCURACY']

  interface CodeLine {
    t: string
    c: string
    i: number
  }

  interface Snippet {
    lang: string
    lines: CodeLine[]
    stat: { value: string; label: string }
  }

  const snippets: Snippet[] = [
    {
      lang: 'JavaScript',
      lines: [
        { t: 'export default defineComponent({', c: 'text-sky-300', i: 0 },
        { t: 'setup() {', c: 'text-sky-300', i: 1 },
        { t: 'const metrics = useVunoMetrics();', c: 'text-cyan-400', i: 2 },
        { t: 'const isLoading = ref(false);', c: 'text-cyan-400', i: 2 },
        { t: 'const grow = (biz) => biz.scale();', c: 'text-cyan-400', i: 2 },
        { t: 'watchEffect(() => {', c: 'text-sky-300', i: 2 },
        { t: 'metrics.track(grow);', c: 'text-cyan-400', i: 2 },
        { t: '});', c: 'text-sky-300', i: 2 },
        { t: 'return { metrics, grow, isLoading }', c: 'text-sky-300', i: 2 },
        { t: '}', c: 'text-sky-300', i: 1 },
        { t: '})', c: 'text-sky-300', i: 0 }
      ],
      stat: { value: '99.9%', label: 'CORE WEB VITALS' }
    },
    {
      lang: 'TypeScript',
      lines: [
        { t: "import { serve } from '@hono/node';", c: 'text-sky-300', i: 0 },
        { t: 'type Metrics = { ok: boolean; data: unknown };', c: 'text-cyan-400', i: 0 },
        { t: 'const app = new Hono();', c: 'text-sky-300', i: 0 },
        { t: "app.get('/api/scale', async (c) => {", c: 'text-sky-300', i: 0 },
        { t: 'const data: Metrics = await db.query(sql);', c: 'text-cyan-400', i: 1 },
        { t: 'return c.json({ ok: true, data });', c: 'text-cyan-400', i: 1 },
        { t: '});', c: 'text-sky-300', i: 0 },
        { t: "app.post('/api/scale', async (c) => {", c: 'text-sky-300', i: 0 },
        { t: 'return c.json({ ok: true });', c: 'text-cyan-400', i: 1 },
        { t: '});', c: 'text-sky-300', i: 0 },
        { t: 'serve({ fetch: app.fetch });', c: 'text-sky-300', i: 0 }
      ],
      stat: { value: '<45ms', label: 'API LATENCY' }
    },
    {
      lang: 'C#',
      lines: [
        { t: '[ApiController]', c: 'text-cyan-400', i: 0 },
        { t: '[Route("api/[controller]")]', c: 'text-cyan-400', i: 0 },
        { t: 'public class MetricsController : ControllerBase', c: 'text-sky-300', i: 0 },
        { t: '{', c: 'text-sky-300', i: 0 },
        { t: '[HttpGet]', c: 'text-cyan-400', i: 1 },
        { t: 'public async Task<IActionResult> Get()', c: 'text-sky-300', i: 1 },
        { t: '{', c: 'text-sky-300', i: 1 },
        { t: 'var data = await _db.QueryAsync(sql);', c: 'text-cyan-400', i: 2 },
        { t: 'return Ok(data);', c: 'text-cyan-400', i: 2 },
        { t: '}', c: 'text-sky-300', i: 1 },
        { t: '}', c: 'text-sky-300', i: 0 }
      ],
      stat: { value: '<50ms', label: 'QUERY TIME' }
    },
    {
      lang: 'Apex',
      lines: [
        { t: '@AuraEnabled', c: 'text-cyan-400', i: 0 },
        { t: 'public static List<Metric__c> getMetrics() {', c: 'text-sky-300', i: 0 },
        { t: 'return [SELECT Id, Name, Value__c', c: 'text-cyan-400', i: 1 },
        { t: 'FROM Metric__c', c: 'text-cyan-400', i: 1 },
        { t: 'ORDER BY CreatedDate DESC', c: 'text-cyan-400', i: 1 },
        { t: 'LIMIT 100];', c: 'text-cyan-400', i: 1 },
        { t: '}', c: 'text-sky-300', i: 0 },
        { t: '@AuraEnabled', c: 'text-cyan-400', i: 0 },
        { t: 'public static Metric__c getById(Id recId) {', c: 'text-sky-300', i: 0 },
        {
          t: 'return [SELECT Id, Name FROM Metric__c WHERE Id = :recId LIMIT 1];',
          c: 'text-cyan-400',
          i: 1
        },
        { t: '}', c: 'text-sky-300', i: 0 }
      ],
      stat: { value: '99.99%', label: 'QUERY ACCURACY' }
    }
  ]

  const indentMap = ['', 'ml-4', 'ml-8']
  const langEl = document.getElementById('code-lang') as HTMLElement
  const accentEl = document.getElementById('hero-accent') as HTMLElement
  let current = 0
  let lineIdx = 0
  let timer: ReturnType<typeof setTimeout> | undefined

  function pad(n: number) {
    return String(n + 1).padStart(2, '0')
  }

  function renderSnippet(idx: number, revealUpTo: number) {
    const sn = snippets[idx]
    container.innerHTML = sn.lines
      .map(
        (l: CodeLine, i: number) =>
          `<p class="${l.c} ${indentMap[l.i] || ''}" style="opacity:${i <= revealUpTo ? 1 : 0}; transition: opacity 0.4s ease">` +
          `<span class="text-on-surface-variant/50">${pad(i)}</span> ${l.t}` +
          `${i === revealUpTo ? '<span class="animate-pulse text-cyan-400">▊</span>' : ''}` +
          `</p>`
      )
      .join('')
  }

  function updateStat(sn: Snippet) {
    const el = document.getElementById('stat-value')
    const labelEl = document.getElementById('stat-label')
    if (el) {
      el.style.opacity = '0'
      el.style.transform = 'translateY(8px)'
      setTimeout(() => {
        el.textContent = sn.stat.value
        el.style.opacity = '1'
        el.style.transform = 'translateY(0)'
      }, 200)
    }
    if (labelEl && statLabels[current]) {
      labelEl.textContent = statLabels[current]
    }
  }

  function nextSnippet() {
    current = (current + 1) % snippets.length
    lineIdx = 0
    const sn = snippets[current]
    container.innerHTML = sn.lines
      .map(
        (l: CodeLine, i: number) =>
          `<p class="${l.c} ${indentMap[l.i] || ''}" style="opacity:0; transition: opacity 0.4s ease">` +
          `<span class="text-on-surface-variant/50">${pad(i)}</span> ${l.t}</p>`
      )
      .join('')
    if (langEl) langEl.textContent = sn.lang
    if (accentEl) {
      accentEl.classList.add('hero-glow-pulse')
      setTimeout(() => accentEl.classList.remove('hero-glow-pulse'), 600)
    }
    updateStat(sn)
    revealLines()
  }

  function revealLines() {
    const sn = snippets[current]
    if (lineIdx >= sn.lines.length) {
      clearTimeout(timer)
      timer = setTimeout(nextSnippet, 3000)
      return
    }
    renderSnippet(current, lineIdx)
    lineIdx++
    const delay = lineIdx === 1 ? 400 : 120
    timer = setTimeout(revealLines, delay)
  }

  function animateMobileCode() {
    const mc = document.getElementById('mobile-code')
    if (!mc) return
    const lines = Array.from(mc.children) as HTMLElement[]
    if (!lines.length) return
    let idx = 0
    function revealNext() {
      if (idx >= lines.length) {
        setTimeout(animateMobileCode, 4000)
        return
      }
      lines[idx].style.opacity = '1'
      lines.forEach(l => l.querySelector('.cursor')?.remove())
      lines[idx].insertAdjacentHTML('beforeend', '<span class="cursor animate-pulse text-cyan-400">▊</span>')
      idx++
      setTimeout(revealNext, idx === 1 ? 600 : 120)
    }
    lines.forEach(l => l.style.opacity = '0')
    revealNext()
  }

  renderSnippet(0, -1)
  revealLines()
  animateMobileCode()

  if (document.querySelector('[data-scroll-lock]')) {
    let unlocked = false
    const unlock = () => {
      if (unlocked) return
      unlocked = true
      document.body.style.overflow = ''
      document.removeEventListener('wheel', unlock)
      document.removeEventListener('touchmove', unlock)
      document.removeEventListener('keydown', unlockOnKey)
    }

    const unlockOnKey = (e: KeyboardEvent) => {
      if (e.key === 'Escape' || e.key === ' ' || e.key === 'Enter' || e.key === 'Tab' || e.key === 'ArrowDown') {
        if (e.key === ' ' || e.key === 'Enter') {
          e.preventDefault()
        }
        unlock()
      }
    }

    document.body.style.overflow = 'hidden'

    document.addEventListener('wheel', unlock, { passive: true })
    document.addEventListener('touchmove', unlock, { passive: true })
    document.addEventListener('keydown', unlockOnKey)
  }
</script>

<style>
#stat-value {
    transition:
      opacity 0.3s ease,
      transform 0.3s ease;
  }
  #code-lang {
    transition: color 0.4s ease;
  }
  .hero-glow-pulse {
    animation: glowPulse 0.6s ease-out;
  }
  @keyframes glowPulse {
    0% {
      text-shadow: 0 0 0px rgba(34, 211, 238, 0);
    }
    50% {
      text-shadow:
        0 0 30px rgba(34, 211, 238, 0.6),
        0 0 60px rgba(34, 211, 238, 0.3);
    }
    100% {
      text-shadow: 0 0 0px rgba(34, 211, 238, 0);
    }
  }
  #code-panel {
    animation: panelBreath 4s ease-in-out infinite;
  }
  @keyframes panelBreath {
    0%,
    100% {
      box-shadow: 0 0 0px rgba(34, 211, 238, 0);
    }
    50% {
      box-shadow: 0 0 40px rgba(34, 211, 238, 0.08);
    }
  }
  .left-col > * {
    opacity: 0;
    animation: fadeUp 0.6s ease forwards;
  }
  .left-col > :nth-child(1) {
    animation-delay: 0.1s;
  }
  .left-col > :nth-child(2) {
    animation-delay: 0.25s;
  }
  .left-col > :nth-child(3) {
    animation-delay: 0.4s;
  }
  .left-col > :nth-child(4) {
    animation-delay: 0.55s;
  }
  @keyframes fadeUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  #mobile-code > p {
    opacity: 0;
    transition: opacity 0.4s ease;
  }
</style>
