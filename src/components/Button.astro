---
export interface Props {
  variant?: 'primary' | 'secondary' | 'ghost';
  size?: 'sm' | 'md' | 'lg';
  href?: string;
  type?: 'button' | 'submit';
  class?: string;
  title?: string;
}

const { variant = 'primary', size = 'md', href, type = 'button', title } = Astro.props;

const base = 'inline-flex items-center justify-center gap-base font-bold transition-all cursor-pointer';

const variants: Record<string, string> = {
  primary: 'bg-electric-blue text-azure-deep hover:shadow-[0_0_20px_rgba(0,168,255,0.4)]',
  secondary: 'border border-electric-blue text-electric-blue hover:bg-electric-blue/10',
  ghost: 'text-on-surface-variant hover:text-electric-blue',
};

const sizes: Record<string, string> = {
  sm: 'px-4 py-2 text-sm rounded-lg',
  md: 'px-6 py-3 text-body-md rounded-lg',
  lg: 'px-8 py-4 text-body-md rounded-lg',
};
---

{
  href ? (
    <a href={href} title={title} class:list={[base, variants[variant], sizes[size], Astro.props.class]}>
      <slot />
    </a>
  ) : (
    <button type={type} title={title} class:list={[base, variants[variant], sizes[size], Astro.props.class]}>
      <slot />
    </button>
  )
}
