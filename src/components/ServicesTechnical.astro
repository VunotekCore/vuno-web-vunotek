---
import ScrollReveal from './ScrollReveal.astro'
import Icon from './Icon.astro';

export interface ServiceItem {
  id: string
  index: string
  icon?: string
  category: string
  title: string
  business_focus: string
  capabilities_title: string
  capabilities: string[]
  stack_tags: string[]
}

export interface Props {
  items: ServiceItem[]
  ctaLabel: string
  ctaHref: string
}

const { items, ctaLabel, ctaHref } = Astro.props
---

<div class="flex flex-col">
  {items.map((item, i) => (
    <ScrollReveal delay={i * 100} stagger>
      <div class="service-block pb-lg">
        {i > 0 && <div class="h-px bg-outline-variant/10 mb-lg"></div>}

        <!-- Header: icon + step badge + category -->
        <div class="flex items-center gap-sm mb-base">
          {item.icon && (
            <Icon name={item.icon} class="text-vue-green text-xl" />
          )}
          <span class="font-label-mono text-label-mono text-vue-green/70 tracking-wider">{item.index}</span>
          <span class="h-px w-6 bg-vue-green/30"></span>
          <span class="font-label-mono text-label-mono text-slate-text uppercase tracking-widest text-xs">
            {item.category}
          </span>
        </div>

        <!-- Main content: 2-col grid -->
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-md">
          <!-- Left: Business focus + stack tags -->
          <div class="lg:col-span-6 flex flex-col gap-base">
            <h2 class="font-display-lg text-headline-md text-on-surface">
              {item.title}
            </h2>
            <p class="font-body-md text-body-md text-slate-text">
              {item.business_focus}
            </p>
            <div class="flex flex-wrap gap-sm mt-auto pt-sm">
              {item.stack_tags.map((tag) => (
                <span class="font-label-mono text-label-mono text-vue-green bg-vue-green/10 border border-vue-green/20 px-2.5 py-0.5 rounded-md">
                  {tag}
                </span>
              ))}
            </div>
          </div>

          <!-- Right: Technical capabilities -->
          <div class="lg:col-span-6">
            <div class="bg-surface-container-low border border-outline-variant/10 rounded-xl max-sm:px-md px-lg py-md flex flex-col gap-sm h-full transition-all duration-300 hover:border-vue-green/50 relative overflow-hidden"
              data-glass-card
              style="--mouse-x: 50%; --mouse-y: 50%;"
            >
              <div class="pointer-events-none absolute -inset-px rounded-xl opacity-0 transition-opacity duration-300"
                style="background: radial-gradient(600px circle at var(--mouse-x, 50%) var(--mouse-y, 50%), rgba(66,184,131,0.08), transparent 60%);"
                data-glass-glow
              />
              <div class="relative z-10">
                <h3 class="font-label-mono text-label-mono text-vue-green tracking-wider uppercase text-xs">
                  {item.capabilities_title}
                </h3>
                <ul class="flex flex-col gap-xs">
                  {item.capabilities.map((cap) => (
                    <li class="flex items-start gap-sm">
                      <span class="text-vue-green font-label-mono text-xs mt-0.5 flex-shrink-0">▹</span>
                      <span class="font-body-md text-body-md text-slate-text">{cap}</span>
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          </div>
        </div>

        <!-- CTA link -->
        <div class="mt-base">
          <a
            href={ctaHref}
            class="inline-flex items-center gap-sm font-label-mono text-label-mono text-vue-green/70 hover:text-vue-green transition-colors group text-xs"
          >
            {ctaLabel}
            <span class="inline-block transition-transform duration-300 group-hover:translate-x-1">→</span>
          </a>
        </div>
      </div>
    </ScrollReveal>
  ))}
</div>


