---
import GlassCard from './GlassCard.astro';

export interface Props {
  quote: string;
  name: string;
  role: string;
  company: string;
}
const { quote, name, role, company } = Astro.props;
---

<GlassCard class="p-lg flex flex-col gap-md">
  <svg class="w-8 h-8 text-electric-blue/40" fill="currentColor" viewBox="0 0 24 24">
    <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/>
  </svg>
  <p class="font-body-lg text-body-lg text-on-surface italic">"{quote}"</p>
  <div class="flex items-center gap-base mt-auto">
    <div class="w-12 h-12 rounded-full bg-electric-blue/20 flex items-center justify-center font-bold text-electric-blue text-lg">
      {name.charAt(0)}
    </div>
    <div>
      <p class="font-headline-md text-headline-md text-on-surface">{name}</p>
      <p class="font-label-mono text-label-mono text-slate-text">{role}, {company}</p>
    </div>
  </div>
</GlassCard>
