---
import BaseLayout from '../layouts/BaseLayout.astro'
import { getPageMeta } from '../seo'

const pageMeta = getPageMeta('es', 'notFound')
---

<BaseLayout
  title={pageMeta?.title ?? ''}
  description={pageMeta?.description ?? ''}
  robots={pageMeta?.robots ?? 'noindex, follow'}
  esUrl="https://vunotek.com/"
  enUrl="https://vunotek.com/en/"
>
  <div class="min-h-screen flex items-center justify-center">
    <div class="flex flex-col items-center gap-md text-center px-margin">
      <a href="/" class="flex items-center gap-3 mb-sm">
        <span class="font-display-lg text-headline-md font-bold tracking-tight"><span class="text-on-surface">VUNO</span><span class="text-electric-blue">TEK</span></span>
      </a>
      <h1 class="font-display-lg text-headline-lg text-on-surface">404</h1>
      <p class="font-body-lg text-body-lg text-slate-text max-w-md">
        La página que buscas no existe o fue movida.
      </p>
      <a href="/" class="font-label-mono text-electric-blue hover:underline">Volver al inicio</a>
    </div>
  </div>
</BaseLayout>