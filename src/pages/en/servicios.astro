---
import BaseLayout from '../../layouts/BaseLayout.astro'
import Servicios from '../../templates/Servicios.astro'
import { getTranslations } from '../../i18n/utils'

const dict = getTranslations(Astro.currentLocale ?? 'en') as any
const svp = dict.services_page
---

<BaseLayout title={svp.meta.title} description={svp.hero.description} breadcrumbName="Services">
  <Servicios dict={dict} locale={Astro.currentLocale ?? 'en'} />
</BaseLayout>
