---
import BaseLayout from '../../layouts/BaseLayout.astro'
import About from '../../templates/About.astro'
import { getPageMeta } from '../../seo'
import { getTranslations } from '../../i18n/utils'

const locale = Astro.currentLocale ?? 'en'
const dict = getTranslations(locale) as any
const pageMeta = getPageMeta(locale, 'about')
---

<BaseLayout title={pageMeta?.title || 'Vunotek'} description={pageMeta?.description || ''} breadcrumbName="About">
  <About dict={dict} locale={locale} />
</BaseLayout>
