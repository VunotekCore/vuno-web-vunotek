---
import BaseLayout from '../../layouts/BaseLayout.astro'
import Contacto from '../../templates/Contacto.astro'
import { getPageMeta } from '../../seo'
import { getTranslations } from '../../i18n/utils'

const locale = Astro.currentLocale ?? 'en'
const pageMeta = getPageMeta(locale, 'contact')
const dict = getTranslations(locale) as any
---

<BaseLayout title={pageMeta?.title || 'Vunotek'} description={pageMeta?.description || ''} breadcrumbName="Contact">
  <Contacto dict={dict} locale={locale} />
</BaseLayout>
