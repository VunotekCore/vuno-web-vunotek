---
import BaseLayout from '../../layouts/BaseLayout.astro'
import Contacto from '../../templates/Contacto.astro'
import { getTranslations } from '../../i18n/utils'

const dict = getTranslations(Astro.currentLocale ?? 'es') as any
const ct = dict.contact_page
---

<BaseLayout title={ct.meta.title} description={ct.hero.description}>
  <Contacto dict={dict} locale={Astro.currentLocale ?? 'es'} />
</BaseLayout>
