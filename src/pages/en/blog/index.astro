---
import BaseLayout from '../../../layouts/BaseLayout.astro'
import Section from '../../../components/Section.astro'
import BlogList from '../../../components/BlogList.vue'
import { getTranslations } from '../../../i18n/utils'

const dict = getTranslations('en') as any
const bg = dict.blog
---

<BaseLayout title={bg.hero.title + ' | Vunotek'} description={bg.hero.desc}>
  <Section class="!pt-32 md:!pt-40 !pb-lg md:!pb-xl">
    <div class="flex flex-col gap-base stagger-header">
      <div class="inline-flex items-center gap-sm bg-surface-charcoal/50 border border-electric-blue/30 w-fit px-4 py-1.5 rounded-full">
        <span class="w-2 h-2 rounded-full bg-electric-blue animate-pulse"></span>
        <span class="font-label-mono text-label-mono text-electric-blue tracking-wider uppercase">{bg.meta?.section_tag || '// blog'}</span>
      </div>
      <h1 class="font-display-lg text-headline-lg-mobile md:text-headline-lg text-on-surface max-w-4xl">
        {bg.hero.title}
      </h1>
      <p class="font-body-lg text-body-lg text-slate-text max-w-3xl">
        {bg.hero.desc}
      </p>
    </div>
  </Section>

  <Section class="bg-surface-container-lowest border-y border-outline-variant/10">
    <BlogList client:idle locale="en" />
  </Section>
</BaseLayout>


