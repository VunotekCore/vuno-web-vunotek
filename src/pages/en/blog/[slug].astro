---
import BaseLayout from '../../../layouts/BaseLayout.astro'
import Section from '../../../components/Section.astro'
import Icon from '../../../components/atoms/Icon.astro'
import BlogPost from '../../../components/BlogPost.vue'
import { getTranslations } from '../../../i18n/utils'

const dict = getTranslations('en') as any
const bg = dict.blog

interface PostData {
  id: number
  title: string
  slug: string
  excerpt: string
  content: string
  category_name: string
  category_slug: string
  author: string
  image: string | null
  meta_title: string | null
  og_image: string | null
  created_at: string
}

export async function getStaticPaths() {
  const apiBase = import.meta.env.DEV ? 'http://localhost:8000' : (import.meta.env.PUBLIC_API_URL || 'http://localhost:8000')
  try {
    const res = await fetch(`${apiBase}/blog/list.php?locale=en&status=published`)
    const data = await res.json()
    if (data.success && Array.isArray(data.data?.posts)) {
      return data.data.posts.map((post: { slug: string }) => ({
        params: { slug: post.slug },
        props: { initialPost: post as PostData },
      }))
    }
  } catch {
    // API not available at build time
  }
  return []
}

const { initialPost } = Astro.props as { initialPost?: PostData }
const pageTitle = initialPost?.meta_title || (initialPost ? `${initialPost.title} | Vunotek` : 'Blog | Vunotek')
const pageDescription = initialPost?.excerpt || 'Articles about software engineering and business automation.'
const publishDate = initialPost?.created_at ? new Date(initialPost.created_at).toISOString() : undefined
---

<BaseLayout title={pageTitle} description={pageDescription} ogType="article" ogImage={initialPost?.og_image || undefined} breadcrumbName={initialPost?.title} articlePublishedTime={publishDate} articleModifiedTime={publishDate} articleAuthor={initialPost?.author || 'Daniel Flores'} articleSection={initialPost?.category_name || 'Blog'}>
  <Section class="!pt-32 md:!pt-40 !pb-lg md:!pb-xl">
    <a href="/en/blog" class="inline-flex items-center gap-xs text-electric-blue font-label-mono hover:underline mb-lg">
      <Icon name="arrow_back" class="text-sm" />
      {bg.back_link}
    </a>
  </Section>

  <Section class="bg-surface-container-lowest border-y border-outline-variant/10">
    {initialPost && (
      <div class="max-w-4xl mx-auto px-margin">
        <div class="flex flex-wrap items-center gap-3 mb-md">
          {initialPost.category_name && (
            <span class="font-label-mono text-[11px] text-electric-blue bg-electric-blue/10 px-3 py-1 rounded">
              {initialPost.category_name}
            </span>
          )}
          <time class="font-label-mono text-[11px] text-slate-text" datetime={publishDate}>
            {new Date(initialPost.created_at).toISOString().split('T')[0]}
          </time>
          <span class="font-label-mono text-[11px] text-slate-text/60">
            — {initialPost.author || 'Daniel Flores'}
          </span>
        </div>
        <h1 class="font-display-lg text-headline-lg-mobile md:text-headline-lg text-on-surface max-w-4xl">
          {initialPost.title}
        </h1>
      </div>
    )}
    <BlogPost client:load locale="en" backUrl="/en/blog" backLabel={bg.back_link} relatedTitle={bg.related_title} initialPost={initialPost || null} shellRendered={!!initialPost} />
  </Section>
</BaseLayout>
