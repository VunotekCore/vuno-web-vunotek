---
import BaseLayout from '../../../layouts/BaseLayout.astro'
import Section from '../../../components/Section.astro'
import ScrollReveal from '../../../components/ScrollReveal.astro'
import BlogCard from '../../../components/BlogCard.astro'
import { getCollection } from 'astro:content'
import type { GetStaticPathsItem } from 'astro'
import { getTranslations } from '../../../i18n/utils'

export async function getStaticPaths(): Promise<GetStaticPathsItem[]> {
  const posts = await getCollection('blog')
  return posts
    .filter((p) => p.data.locale === 'en')
    .map((post) => ({
      params: { slug: post.id },
      props: { post },
    }))
}

const dict = getTranslations(Astro.currentLocale ?? 'en') as any
const bg = dict.blog

const { post } = Astro.props as any

const blogImages: Record<string, string> = {
  'blog/salesforce-automation': 'https://placehold.co/1200x520/1e293b/42b883?text=Salesforce',
  'blog/e-invoicing-central-america': 'https://placehold.co/1200x520/1e293b/42b883?text=E-Invoicing',
  'blog/vue3-astro': 'https://placehold.co/1200x520/1e293b/42b883?text=Vue+3+%2B+Astro',
  'blog/sql-server-optimization': 'https://placehold.co/1200x520/1e293b/42b883?text=SQL+Server',
  'blog/offline-first': 'https://placehold.co/1200x520/1e293b/42b883?text=Offline+First',
  'blog/nodejs-aws-docker': 'https://placehold.co/1200x520/1e293b/42b883?text=Node.js+%2B+AWS',
  'blog/typescript-avanzado': 'https://placehold.co/1200x520/1e293b/42b883?text=TypeScript',
}
const isDirectUrl = post.data.image?.startsWith('http')
const imgSrc = post.data.image
  ? isDirectUrl
    ? post.data.image
    : blogImages[post.data.image]
  : undefined

const allBlogPosts = await getCollection('blog')
const related = allBlogPosts
  .filter((p) =>
    p.data.locale === 'en' &&
    p.data.category === post.data.category &&
    p.id !== post.id
  )
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3)
---

<BaseLayout title={`${post.data.title} | Vunotek`} description={post.data.excerpt}>
  <Section class="!pt-32 md:!pt-40 !pb-lg md:!pb-xl">
    <a href="/en/blog" class="inline-flex items-center gap-xs text-vue-green font-label-mono hover:underline mb-lg">
      <span class="material-symbols-outlined text-sm">arrow_back</span>
      {bg.back_link}
    </a>

    <div class="flex flex-wrap items-center gap-3 mb-md">
      <span class="font-label-mono text-[11px] text-vue-green bg-vue-green/10 px-3 py-1 rounded">{post.data.category}</span>
      <span class="font-label-mono text-[11px] text-slate-text">{post.data.date.toISOString().split('T')[0]}</span>
      <span class="font-label-mono text-[11px] text-slate-text/60">— {post.data.author}</span>
    </div>

    <h1 class="font-display-lg text-headline-lg-mobile md:text-headline-lg text-on-surface max-w-4xl">
      {post.data.title}
    </h1>

    {
      imgSrc && (
        <div class="aspect-[21/9] glass-panel rounded-xl mt-xl overflow-hidden">
          <img src={imgSrc} alt={post.data.title} class="w-full h-full object-cover" loading="eager" />
        </div>
      )
    }
  </Section>

  <Section class="bg-surface-container-lowest border-y border-outline-variant/10">
    <div class="max-w-3xl mx-auto">
      <div class="blog-content">
        <Fragment set:html={post.rendered?.html || ''} />
      </div>
    </div>
  </Section>

  {
    related.length > 0 && (
      <Section>
        <h2 class="font-display-lg text-headline-lg text-on-surface mb-lg">
          {bg.related_title}
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-md">
          {related.map((rp, i) => (
            <ScrollReveal delay={i * 100} stagger>
              <BlogCard
                title={rp.data.title}
                excerpt={rp.data.excerpt}
                date={rp.data.date.toISOString().split('T')[0]}
                category={rp.data.category}
                slug={rp.id}
                image={rp.data.image}
              />
            </ScrollReveal>
          ))}
        </div>
      </Section>
    )
  }
</BaseLayout>

<style>
  .material-symbols-outlined {
    font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
  }

  .blog-content {
    font-size: 1.0625rem;
    line-height: 1.85;
    color: #c8d0e0;
  }

  .blog-content h1 {
    font-size: 1.75rem;
    line-height: 2.25rem;
    font-weight: 700;
    color: #dae2fd;
    margin-top: 3rem;
    margin-bottom: 1rem;
    letter-spacing: -0.02em;
  }

  .blog-content h2 {
    font-size: 1.5rem;
    line-height: 2rem;
    font-weight: 600;
    color: #dae2fd;
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid rgba(66, 184, 131, 0.12);
    letter-spacing: -0.01em;
  }

  .blog-content h3 {
    font-size: 1.25rem;
    line-height: 1.75rem;
    font-weight: 600;
    color: #e2e8f8;
    margin-top: 2rem;
    margin-bottom: 0.5rem;
  }

  .blog-content p {
    margin-bottom: 1.25rem;
    line-height: 1.85;
    color: #c8d0e0;
  }

  .blog-content ul, .blog-content ol {
    margin-bottom: 1.25rem;
    padding-left: 1.5rem;
    color: #c8d0e0;
  }

  .blog-content li {
    margin-bottom: 0.5rem;
    line-height: 1.75;
  }

  .blog-content ul li {
    list-style-type: disc;
  }

  .blog-content ul li::marker {
    color: #42b883;
  }

  .blog-content ol li {
    list-style-type: decimal;
  }

  .blog-content ol li::marker {
    color: #42b883;
    font-weight: 600;
  }

  .blog-content strong {
    color: #e8edf8;
    font-weight: 600;
  }

  .blog-content code {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.8125rem;
    background: rgba(30, 41, 59, 0.9);
    padding: 0.2rem 0.5rem;
    border-radius: 0.375rem;
    color: #69dca4;
    border: 1px solid rgba(66, 184, 131, 0.18);
    white-space: nowrap;
  }

  .blog-content pre {
    background: #0a1022;
    border: 1px solid rgba(64, 73, 68, 0.35);
    border-left: 3px solid #42b883;
    border-radius: 0.75rem;
    padding: 1.5rem 2rem;
    margin-top: 1.5rem;
    margin-bottom: 1.75rem;
    overflow-x: auto;
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.3);
  }

  .blog-content pre code {
    background: none;
    border: none;
    padding: 0;
    color: #dae2fd;
    font-size: 0.925rem;
    line-height: 1.7;
    white-space: pre;
    tab-size: 2;
  }

  .blog-content blockquote {
    border-left: 3px solid #42b883;
    padding: 0.75rem 1.25rem;
    margin: 1.5rem 0;
    background: rgba(66, 184, 131, 0.06);
    border-radius: 0 0.5rem 0.5rem 0;
    color: #94a3b8;
    font-style: italic;
  }

  .blog-content hr {
    border: none;
    border-top: 1px solid rgba(64, 73, 68, 0.3);
    margin: 2.5rem 0;
  }

  .blog-content a {
    color: #42b883;
    text-decoration: underline;
    text-underline-offset: 2px;
    text-decoration-thickness: 1px;
    transition: color 0.2s;
  }

  .blog-content a:hover {
    color: #69dca4;
    text-decoration-thickness: 2px;
  }

  .blog-content img {
    border-radius: 0.75rem;
    margin: 1.5rem auto;
    border: 1px solid rgba(64, 73, 68, 0.3);
  }
</style>
