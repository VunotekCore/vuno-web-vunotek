---
import BaseLayout from '../../../layouts/BaseLayout.astro'
import Section from '../../../components/Section.astro'
import Icon from '../../../components/atoms/Icon.astro'
import BlogPost from '../../../components/BlogPost.vue'
import { getTranslations } from '../../../i18n/utils'

const dict = getTranslations('en') as any
const bg = dict.blog

interface PostData {
  id: number
  title: string
  slug: string
  excerpt: string
  content: string
  category_name: string
  category_slug: string
  author: string
  image: string | null
  meta_title: string | null
  og_image: string | null
  created_at: string
}

export async function getStaticPaths() {
  const apiBase = import.meta.env.PUBLIC_API_URL || 'http://localhost:8000'
  try {
    const res = await fetch(`${apiBase}/blog/list.php?locale=en&status=published`)
    const data = await res.json()
    if (data.success && Array.isArray(data.data?.posts)) {
      return data.data.posts.map((post: { slug: string }) => ({
        params: { slug: post.slug },
        props: { initialPost: post as PostData },
      }))
    }
  } catch {
    // API not available at build time
  }
  return []
}

const { initialPost } = Astro.props as { initialPost?: PostData }
const pageTitle = initialPost?.meta_title || (initialPost ? `${initialPost.title} | Vunotek` : 'Blog | Vunotek')
const pageDescription = initialPost?.excerpt || 'Articles about software engineering and business automation.'
---

<BaseLayout title={pageTitle} description={pageDescription} ogType="article" ogImage={initialPost?.og_image || undefined} breadcrumbName={initialPost?.title}>
  <Section class="!pt-32 md:!pt-40 !pb-lg md:!pb-xl">
    <a href="/en/blog" class="inline-flex items-center gap-xs text-electric-blue font-label-mono hover:underline mb-lg">
      <Icon name="arrow_back" class="text-sm" />
      {bg.back_link}
    </a>
  </Section>

  <Section class="bg-surface-container-lowest border-y border-outline-variant/10">
    <BlogPost client:load locale="en" backUrl="/en/blog" backLabel={bg.back_link} relatedTitle={bg.related_title} initialPost={initialPost || null} />
  </Section>
</BaseLayout>

<style is:global>
.blog-content {
    font-size: 1.0625rem;
    line-height: 1.85;
    color: #c8d0e0;
  }

  .blog-content h1 {
    font-size: 1.75rem;
    line-height: 2.25rem;
    font-weight: 700;
    color: #dae2fd;
    margin-top: 3rem;
    margin-bottom: 1rem;
    letter-spacing: -0.02em;
  }

  .blog-content h2 {
    font-size: 1.5rem;
    line-height: 2rem;
    font-weight: 600;
    color: #dae2fd;
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid rgba(0, 168, 255, 0.12);
    letter-spacing: -0.01em;
  }

  .blog-content h3 {
    font-size: 1.25rem;
    line-height: 1.75rem;
    font-weight: 600;
    color: #e2e8f8;
    margin-top: 2rem;
    margin-bottom: 0.5rem;
  }

  .blog-content p {
    margin-bottom: 1.25rem;
    line-height: 1.85;
    color: #c8d0e0;
  }

  .blog-content ul, .blog-content ol {
    margin-bottom: 1.25rem;
    padding-left: 1.5rem;
    color: #c8d0e0;
  }

  .blog-content li {
    margin-bottom: 0.5rem;
    line-height: 1.75;
  }

  .blog-content ul li {
    list-style-type: disc;
  }

  .blog-content ul li::marker {
    color: #00A8FF;
  }

  .blog-content ol li {
    list-style-type: decimal;
  }

  .blog-content ol li::marker {
    color: #00A8FF;
    font-weight: 600;
  }

  .blog-content strong {
    color: #e8edf8;
    font-weight: 600;
  }

  .blog-content code {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.8125rem;
    background: rgba(30, 41, 59, 0.9);
    padding: 0.2rem 0.5rem;
    border-radius: 0.375rem;
    color: #4DC8FF;
    border: 1px solid rgba(0, 168, 255, 0.18);
    overflow-wrap: break-word;
    word-break: break-word;
  }

  .blog-content pre {
    background: #0a1022;
    border: 1px solid rgba(64, 73, 68, 0.35);
    border-left: 3px solid #00A8FF;
    border-radius: 0.75rem;
    padding: 1.5rem 2rem;
    margin-top: 1.5rem;
    margin-bottom: 1.75rem;
    overflow-x: auto;
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.3);
  }

  .blog-content pre code {
    background: none;
    border: none;
    padding: 0;
    color: #dae2fd;
    font-size: 0.925rem;
    line-height: 1.7;
    white-space: pre;
    tab-size: 2;
  }

  .blog-content blockquote {
    border-left: 3px solid #00A8FF;
    padding: 0.75rem 1.25rem;
    margin: 1.5rem 0;
    background: rgba(0, 168, 255, 0.06);
    border-radius: 0 0.5rem 0.5rem 0;
    color: #94a3b8;
    font-style: italic;
  }

  .blog-content hr {
    border: none;
    border-top: 1px solid rgba(64, 73, 68, 0.3);
    margin: 2.5rem 0;
  }

  .blog-content a {
    color: #00A8FF;
    text-decoration: underline;
    text-underline-offset: 2px;
    text-decoration-thickness: 1px;
    transition: color 0.2s;
  }

  .blog-content a:hover {
    color: #4DC8FF;
    text-decoration-thickness: 2px;
  }

  .blog-content img {
    max-width: 100%;
    height: auto;
    border-radius: 0.75rem;
    margin: 1.5rem auto;
    border: 1px solid rgba(64, 73, 68, 0.3);
  }
</style>
