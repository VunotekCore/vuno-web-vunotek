---
import BaseLayout from '../../layouts/BaseLayout.astro'
import Home from '../../templates/Home.astro'
import { getTranslations } from '../../i18n/utils'
import { getPageMeta } from '../../seo'

const dict = getTranslations(Astro.currentLocale ?? 'en') as any
const locale = Astro.currentLocale ?? 'en'
const pageMeta = getPageMeta(locale, 'home')
---

<BaseLayout title={pageMeta?.title ?? ''} description={pageMeta?.description ?? ''}>
  <Home dict={dict} locale={locale} />
</BaseLayout>
