---
import AdminLayout from '../../../layouts/AdminLayout.astro'
import CategoryForm from '../../../components/admin/CategoryForm.vue'

export function getStaticPaths() {
  return [{ params: { id: '1' } }]
}

const { id } = Astro.params
---

<AdminLayout title="Editar categoría">
  <div class="mb-6">
    <a href="/admin/categories" class="inline-flex items-center gap-1 text-sm text-on-surface-variant hover:text-on-surface transition-colors">
      <span class="material-symbols-rounded text-lg">arrow_back</span>
      Volver a categorías
    </a>
  </div>
  <CategoryForm categoryId={id} client:only="vue" />
</AdminLayout>
