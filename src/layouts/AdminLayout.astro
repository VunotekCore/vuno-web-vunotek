---
import '../styles/global.css'

export interface Props {
  title: string
}

const { title } = Astro.props
const currentPath = Astro.url.pathname

const navItems = [
  { href: '/admin', label: 'Dashboard', icon: 'grid_view' },
  { href: '/admin/blog', label: 'Blog', icon: 'article' },
  { href: '/admin/categories', label: 'Categorías', icon: 'label' },
]
---

<html class="dark" lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <title>{title} — Vunotek Admin</title>
    <link rel="icon" type="image/svg+xml" href="/vunotek-isotipo-square.svg" />
  </head>
  <body class="bg-background text-on-surface font-body-md antialiased">
    <div class="flex min-h-screen">
      <aside
        id="admin-sidebar"
        class="fixed inset-y-0 left-0 z-40 flex w-[260px] flex-col border-r border-outline-variant/20 bg-surface-container-lowest transition-transform duration-300 max-lg:-translate-x-full max-lg:shadow-xl"
      >
        <div class="flex h-16 items-center gap-sm border-b border-outline-variant/20 px-5">
          <a href="/admin" class="flex items-center gap-sm">
            <span class="font-display-lg text-headline-md text-on-surface">VUNO</span>
            <span class="font-display-lg text-headline-md text-vue-green">TEK</span>
          </a>
          <span class="ml-auto rounded bg-vue-green/15 px-2 py-0.5 text-xs font-medium text-vue-green">Admin</span>
        </div>

        <nav class="flex-1 overflow-y-auto py-4">
          <ul class="flex flex-col gap-1 px-3">
            {navItems.map((item) => {
              const isActive = item.href === '/admin'
                ? currentPath === '/admin' || currentPath === '/admin/'
                : currentPath.startsWith(item.href)
              return (
                <li>
                  <a
                    href={item.href}
                    class:list={[
                      'flex items-center gap-3 rounded-lg px-3 py-2.5 text-body-md font-medium transition-colors',
                      isActive
                        ? 'bg-vue-green/10 text-vue-green'
                        : 'text-on-surface-variant hover:bg-surface-container-high hover:text-on-surface',
                    ]}
                  >
                    <span class="material-symbols-rounded text-xl">{item.icon}</span>
                    {item.label}
                  </a>
                </li>
              )
            })}
          </ul>
        </nav>

        <div class="border-t border-outline-variant/20 p-3">
          <a
            href="/"
            target="_blank"
            class="flex items-center gap-3 rounded-lg px-3 py-2.5 text-body-md text-on-surface-variant transition-colors hover:bg-surface-container-high hover:text-on-surface"
          >
            <span class="material-symbols-rounded text-xl">open_in_new</span>
            Ver sitio web
          </a>
          <button
            id="admin-logout"
            class="flex w-full items-center gap-3 rounded-lg px-3 py-2.5 text-body-md text-on-surface-variant transition-colors hover:bg-error-container/20 hover:text-error"
          >
            <span class="material-symbols-rounded text-xl">logout</span>
            Cerrar sesión
          </button>
        </div>
      </aside>

      <div class="flex flex-1 flex-col lg:pl-[260px]">
        <header class="sticky top-0 z-30 flex h-16 items-center gap-4 border-b border-outline-variant/20 bg-surface/80 backdrop-blur-md px-6">
          <button
            id="admin-menu-toggle"
            class="lg:hidden text-on-surface-variant hover:text-on-surface"
            aria-label="Abrir menú"
          >
            <span class="material-symbols-rounded text-2xl">menu</span>
          </button>
          <h1 class="text-headline-md font-display-lg text-on-surface max-sm:text-lg">{title}</h1>
          <div class="ml-auto flex items-center gap-sm">
            <span id="admin-user-name" class="text-sm text-on-surface-variant max-sm:hidden"></span>
          </div>
        </header>

        <main class="flex-1 p-6 lg:p-8">
          <slot />
        </main>
      </div>
    </div>

    <div id="admin-sidebar-overlay" class="fixed inset-0 z-30 hidden bg-black/50 lg:hidden"></div>

    <script>
      const API_URL = (import.meta as any).env?.PUBLIC_API_URL || 'https://api.vunotek.com'
      const token = localStorage.getItem('admin_token')

      if (!token) {
        window.location.href = '/admin/login'
      } else {
        fetch(`${API_URL}/admin/verify.php`, {
          headers: { Authorization: `Bearer ${token}` },
        })
          .then((r) => r.json())
          .then((data) => {
            if (!data.success) {
              localStorage.removeItem('admin_token')
              window.location.href = '/admin/login'
            } else if (data.user?.name) {
              const el = document.getElementById('admin-user-name')
              if (el) el.textContent = data.user.name
            }
          })
          .catch(() => {
            localStorage.removeItem('admin_token')
            window.location.href = '/admin/login'
          })
      }

      const sidebar = document.getElementById('admin-sidebar')!
      const overlay = document.getElementById('admin-sidebar-overlay')!
      const toggle = document.getElementById('admin-menu-toggle')!

      toggle.addEventListener('click', () => {
        sidebar.classList.remove('-translate-x-full')
        overlay.classList.remove('hidden')
      })

      overlay.addEventListener('click', () => {
        sidebar.classList.add('-translate-x-full')
        overlay.classList.add('hidden')
      })

      document.getElementById('admin-logout')?.addEventListener('click', () => {
        localStorage.removeItem('admin_token')
        window.location.href = '/admin/login'
      })
    </script>
  </body>
</html>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Material+Symbols+Rounded:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200&display=swap');
</style>
