---
import '../styles/base.css'
import '../styles/admin.css'
import VunotekLogoMarca from '../components/atoms/VunotekLogoMarca.astro'

export interface Props {
  title: string
}

const { title } = Astro.props
const currentPath = Astro.url.pathname

const navItems = [
  { href: '/admin', label: 'Dashboard', icon: 'grid_view', permission: null },
  { href: '/admin/blog', label: 'Blog', icon: 'article', permission: 'blog' },
  { href: '/admin/categories', label: 'Categorías', icon: 'label', permission: 'categories' },
]
---

<html class="dark" lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <title>{title} — Vunotek Admin</title>
    <link rel="icon" type="image/svg+xml" href="/vunotek-isotipo-square.svg" />
  </head>
  <body class="bg-[#0a1022] text-[#dae2fd] font-body-md antialiased min-h-screen flex">
    <div class="flex min-h-screen w-full">
      <aside
        id="admin-sidebar"
        class="fixed inset-y-0 left-0 z-40 flex w-[260px] flex-col border-r border-[#1e293b] bg-[#0b1326] transition-transform duration-300 max-lg:-translate-x-full max-lg:shadow-xl"
      >
        <div class="flex h-16 items-center gap-sm border-b border-[#1e293b] px-5">
          <a href="/admin" class="flex items-center">
            <VunotekLogoMarca height={28} text="VUNO-TEK" accentColor="#69dca4" />
          </a>
          <span class="ml-auto rounded bg-[#69dca4]/15 px-2 py-0.5 text-xs font-medium text-[#69dca4]">Admin</span>
        </div>

        <nav class="flex-1 overflow-y-auto py-4 sidebar-scroll">
          <ul class="flex flex-col gap-1 px-3">
            {navItems.map((item) => {
              const isActive = item.href === '/admin'
                ? currentPath === '/admin' || currentPath === '/admin/'
                : currentPath.startsWith(item.href)
              return (
                <li>
                  <a
                    href={item.href}
                    data-nav-permission={item.permission || ''}
                    class:list={[
                      'flex items-center gap-3 rounded-lg px-3 py-2.5 text-body-md font-medium transition-colors',
                      isActive
                        ? 'sidebar-link-active'
                        : 'text-[#94a3b8] hover:bg-white/[0.06] hover:text-[#dae2fd]',
                    ]}
                  >
                    <span class="material-symbols-rounded text-xl">{item.icon}</span>
                    {item.label}
                  </a>
                </li>
              )
            })}
          </ul>
        </nav>

        <div class="border-t border-[#1e293b] p-3">
          <a
            href="/"
            target="_blank"
            class="flex items-center gap-3 rounded-lg px-3 py-2.5 text-body-md text-[#94a3b8] transition-colors hover:bg-white/[0.06] hover:text-[#dae2fd]"
          >
            <span class="material-symbols-rounded text-xl">open_in_new</span>
            Ver sitio web
          </a>
          <button
            id="admin-logout"
            class="flex w-full items-center gap-3 rounded-lg px-3 py-2.5 text-body-md text-[#94a3b8] transition-colors hover:bg-white/[0.06] hover:text-[#DC2626]"
          >
            <span class="material-symbols-rounded text-xl">logout</span>
            Cerrar sesión
          </button>
        </div>
      </aside>

      <div class="flex flex-1 flex-col min-w-0 min-h-screen lg:ml-[260px]">
        <header class="sticky top-0 z-30 flex h-16 items-center gap-4 border-b border-[#1e293b] bg-[#111d2e]/80 backdrop-blur-md px-6">
          <button
            id="admin-menu-toggle"
            class="lg:hidden text-[#94a3b8] hover:text-[#dae2fd]"
            aria-label="Abrir menú"
          >
            <span class="material-symbols-rounded text-2xl">menu</span>
          </button>
          <h1 class="font-headline text-headline-md text-[#dae2fd] max-sm:text-lg">{title}</h1>
          <div class="ml-auto flex items-center gap-sm">
            <span id="admin-role-badge" class="hidden rounded-full bg-[#69dca4]/15 px-2.5 py-0.5 text-xs font-medium text-[#69dca4]"></span>
            <span id="admin-user-name" class="text-sm text-[#94a3b8] max-sm:hidden"></span>
          </div>
        </header>

        <main class="flex-1 p-6 lg:p-8">
          <slot />
        </main>
      </div>
    </div>

    <div id="admin-sidebar-overlay" class="fixed inset-0 z-30 hidden bg-[#0b1326]/70 backdrop-blur-md lg:hidden"></div>

    <script>
      import { authService } from '../services/authService'

      const token = localStorage.getItem('admin_token')

      if (!token) {
        window.location.href = '/admin/login'
      } else {
        authService.verify()
          .then(({ data }) => {
            if (!data.success) {
              localStorage.removeItem('admin_token')
              window.location.href = '/admin/login'
              return
            }

            const user = data.data?.user
            const nameEl = document.getElementById('admin-user-name')
            if (nameEl && user?.name) nameEl.textContent = user.name

            const roleEl = document.getElementById('admin-role-badge')
            if (roleEl && user?.role_name) {
              roleEl.textContent = user.role_name
              roleEl.classList.remove('hidden')
            }

            if (user?.permissions && !user.permissions.all) {
              document.querySelectorAll('[data-nav-permission]').forEach((el) => {
                const module = el.getAttribute('data-nav-permission')
                if (module && !user.permissions[module]) {
                  ;(el as HTMLElement).style.display = 'none'
                }
              })
            }
          })
          .catch(() => {
            localStorage.removeItem('admin_token')
            window.location.href = '/admin/login'
          })
      }

      const sidebar = document.getElementById('admin-sidebar')!
      const overlay = document.getElementById('admin-sidebar-overlay')!
      const toggle = document.getElementById('admin-menu-toggle')!

      toggle.addEventListener('click', () => {
        sidebar.classList.remove('-translate-x-full')
        overlay.classList.remove('hidden')
      })

      overlay.addEventListener('click', () => {
        sidebar.classList.add('-translate-x-full')
        overlay.classList.add('hidden')
      })

      document.getElementById('admin-logout')?.addEventListener('click', () => {
        localStorage.removeItem('admin_token')
        window.location.href = '/admin/login'
      })
    </script>
  </body>
</html>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Material+Symbols+Rounded:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200&display=swap');
</style>
