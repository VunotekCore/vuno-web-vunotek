---
import '../styles/global.css';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import PrivacyModal from '../components/PrivacyModal.astro';
import { SEO, getBreadcrumbSchema } from '../seo';

export interface Props {
  title: string;
  description: string;
  esUrl?: string;
  enUrl?: string;
  robots?: string;
  ogType?: string;
  ogImage?: string;
  breadcrumbName?: string;
}

const {
  title,
  description,
  esUrl: explicitEsUrl,
  enUrl: explicitEnUrl,
  robots = 'index, follow',
  ogType = 'website',
  ogImage: ogImageProp,
  breadcrumbName,
} = Astro.props;

const currentLang = Astro.currentLocale || 'es';
const currentPath = Astro.url.pathname;
const siteUrl = Astro.site ? `${Astro.site.origin}` : (import.meta.env.PUBLIC_SITE_URL || 'https://vunotek.com');
const canonicalURL = Astro.site ? new URL(Astro.url.pathname, Astro.site).href : `${siteUrl}${currentPath}`;
const gaId = import.meta.env.PUBLIC_GA_ID;
const isEn = currentLang === 'en';

const currentSlug = currentPath
  .replace(/^\/en\/?/, '')
  .replace(/^\//, '')
  .replace(/\/$/, '');

const ogLocale = isEn ? 'en_US' : 'es_ES';
const locale = isEn ? 'en' : 'es';

const esUrl = explicitEsUrl ?? (currentSlug ? `${siteUrl}/${currentSlug}/` : `${siteUrl}/`);
const enUrl = explicitEnUrl ?? (currentSlug ? `${siteUrl}/en/${currentSlug}/` : `${siteUrl}/en/`);

const orgDesc = SEO.organizationSchema.description[locale];

const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Vunotek',
  url: siteUrl,
  logo: `${siteUrl}/logo.webp`,
  description: orgDesc,
  foundingDate: '2024',
  address: {
    '@type': 'PostalAddress',
    addressCountry: 'NI',
  },
  areaServed: [
    { '@type': 'Country', name: 'Nicaragua' },
    { '@type': 'Country', name: 'Costa Rica' },
    { '@type': 'Country', name: 'Honduras' },
    { '@type': 'Country', name: 'Guatemala' },
    { '@type': 'Country', name: 'El Salvador' },
    { '@type': 'Country', name: 'Panama' },
    { '@type': 'Country', name: 'United States' },
  ],
  knowsAbout: [
    'Software Engineering',
    'Vue.js Development',
    'Node.js Development',
    '.NET Development',
    'Salesforce Integration',
    'Cloud Architecture',
    'AWS Infrastructure',
    'Enterprise Automation',
    'PostgreSQL',
    'TypeScript',
  ],
  contactPoint: {
    '@type': 'ContactPoint',
    email: 'projects@vunotek.com',
    contactType: 'sales',
  },
  sameAs: [
    'https://github.com/vunotek',
    'https://linkedin.com/company/vunotek',
  ],
};

const webSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Vunotek',
  url: siteUrl,
  inLanguage: isEn ? 'en-US' : 'es-ES',
  description: SEO.organizationSchema.description[locale],
};

const breadcrumbSchema = getBreadcrumbSchema(locale, currentPath, breadcrumbName);

const ogImageUrl = ogImageProp || `${siteUrl}/logo.webp`;
const ogImageWidth = '1200';
const ogImageHeight = '630';

const gaSrc = gaId ? `https://www.googletagmanager.com/gtag/js?id=${encodeURIComponent(gaId)}` : '';
const gaScript = gaId ? `window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments);}gtag('js',new Date());gtag('config','${gaId}');` : '';
---

<html class="dark" lang={currentLang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#0a0f1a" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content={robots} />
    <meta name="google-site-verification" content="OLAPWz6sRxKAUk91oJG0dQmfTtv-mFFGoHo-c_wG3DA" />

    <link rel="preconnect" href="https://ik.imagekit.io" />
    {gaId && <link rel="preconnect" href="https://www.googletagmanager.com" />}

    <link rel="preload" href="/fonts/hanken-grotesk-latin-400-normal.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/inter-latin-400-normal.woff2" as="font" type="font/woff2" crossorigin />

    <link rel="canonical" href={canonicalURL} />

    <link rel="alternate" hreflang="es" href={esUrl} />
    <link rel="alternate" hreflang="en" href={enUrl} />
    <link rel="alternate" hreflang="x-default" href={esUrl} />

    <meta property="og:locale" content={ogLocale} />
    <meta property="og:locale:alternate" content={isEn ? 'es_ES' : 'en_US'} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content={ogImageWidth} />
    <meta property="og:image:height" content={ogImageHeight} />
    <meta property="og:site_name" content="Vunotek" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@vunotek" />
    <meta name="twitter:creator" content="@vunotek" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <link rel="icon" type="image/svg+xml" href="/vunotek-isotipo-square.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />

    <script type="application/ld+json" is:inline set:html={JSON.stringify(orgSchema)} />
    <script type="application/ld+json" is:inline set:html={JSON.stringify(webSchema)} />
    {breadcrumbSchema && (
      <script type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumbSchema)} />
    )}

    <script type="speculationrules" is:inline>
    {
      "prerender": [{
        "where": { "href_matches": "/*" },
        "eagerness": "moderate"
      }]
    }
    </script>

  </head>
  <body class="bg-background text-on-surface font-body-md selection:bg-electric-blue/30 selection:text-electric-blue overflow-x-hidden">
    {gaId && <script is:inline set:html={gaScript} />}
    {gaId && <script is:inline src={gaSrc} async />}
    <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:z-50 focus:px-4 focus:py-2 focus:bg-surface-charcoal focus:text-electric-blue focus:outline-none">
      {currentLang === 'en' ? 'Skip to main content' : 'Saltar al contenido principal'}
    </a>
    <Navbar />
    <main id="main-content">
      <slot />
    </main>
    <Footer />
    <PrivacyModal locale={currentLang} />
  </body>
</html>
