---
import Section from '../components/Section.astro'
import ScrollReveal from '../components/ScrollReveal.astro'
import GlassCard from '../components/GlassCard.astro'
import StatCard from '../components/StatCard.astro'

export interface Props {
  dict: Record<string, unknown>
  locale?: string
}

const { dict } = Astro.props
const ab = dict.about as any
---

<!-- ============================================================
  BLOQUE 1 — HERO (Origen y Trayectoria)
  Badge, título con acento gradient, descripción de respaldo.
  Fondo default (sin bg class).
  ============================================================ -->
<Section class="!pt-32 md:!pt-40 !pb-lg md:!pb-xl">
  <div class="flex flex-col gap-base stagger-header">
    <div class="inline-flex items-center gap-sm bg-surface-charcoal/50 border border-vue-green/30 w-fit px-4 py-1.5 rounded-full">
      <span class="w-2 h-2 rounded-full bg-vue-green animate-pulse"></span>
      <span class="font-label-mono text-label-mono text-vue-green tracking-wider uppercase">{ab.hero.badge}</span>
    </div>
    <h1 class="font-display-lg text-headline-lg-mobile md:text-headline-lg text-on-surface max-w-4xl">
      {ab.hero.title}<br />
      <span class="bg-gradient-to-r from-vue-green to-emerald-400 bg-clip-text text-transparent">{ab.hero.titleAccent}</span> {ab.hero.titleRest}
    </h1>
    <p class="font-body-lg text-body-lg text-slate-text max-w-3xl">
      {ab.hero.description}
    </p>
  </div>
</Section>

<!-- ============================================================
  BLOQUE 2 — MANIFIESTO OPERATIVO (Misión, Visión, Objetivos)
  3 columnas en desktop, apilado en mobile.
  Fondo bg-surface-container-lowest con bordes.
  ============================================================ -->
<Section class="bg-surface-container-lowest border-y border-outline-variant/10">
  <div class="grid grid-cols-1 md:grid-cols-3 gap-md">
    <ScrollReveal>
      <GlassCard class="p-lg h-full flex flex-col">
        <span class="material-symbols-outlined text-vue-green text-3xl mb-md">flag</span>
        <h3 class="font-headline-md text-headline-md text-on-surface mb-sm">{ab.pillars.mission.title}</h3>
        <p class="font-body-md text-body-md text-slate-text flex-1">{ab.pillars.mission.desc}</p>
      </GlassCard>
    </ScrollReveal>

    <ScrollReveal delay={100}>
      <GlassCard class="p-lg h-full flex flex-col">
        <span class="material-symbols-outlined text-vue-green text-3xl mb-md">visibility</span>
        <h3 class="font-headline-md text-headline-md text-on-surface mb-sm">{ab.pillars.vision.title}</h3>
        <p class="font-body-md text-body-md text-slate-text flex-1">{ab.pillars.vision.desc}</p>
      </GlassCard>
    </ScrollReveal>

    <ScrollReveal delay={200}>
      <GlassCard class="p-lg h-full flex flex-col">
        <span class="material-symbols-outlined text-vue-green text-3xl mb-md">checklist</span>
        <h3 class="font-headline-md text-headline-md text-on-surface mb-sm">{ab.pillars.objectives.title}</h3>
        <ul class="space-y-sm flex-1">
          {ab.pillars.objectives.items.map((item: string) => (
            <li class="flex items-start gap-sm">
              <span class="material-symbols-outlined text-vue-green text-lg mt-0.5 shrink-0">check_circle</span>
              <span class="font-body-md text-body-md text-slate-text">{item}</span>
            </li>
          ))}
        </ul>
      </GlassCard>
    </ScrollReveal>
  </div>
</Section>

<!-- ============================================================
  BLOQUE 3 — LÍNEA DE EVOLUCIÓN TÉCNICA (Timeline)
  Años como nodos, línea vertical, título + descripción a la derecha.
  Fondo default (sin bg class).
  ============================================================ -->
<Section>
  <ScrollReveal>
    <h2 class="font-display-lg text-headline-lg mb-sm text-center">
      {ab.timeline.title}<br />
      <span class="bg-gradient-to-r from-vue-green to-emerald-400 bg-clip-text text-transparent">{ab.timeline.titleAccent}</span> {ab.timeline.titleRest}
    </h2>
    <p class="font-body-lg text-body-lg text-slate-text max-w-2xl mx-auto text-center mb-xl">{ab.timeline.subtitle}</p>
  </ScrollReveal>

  <div class="relative max-w-4xl mx-auto">
    <div class="absolute left-0 top-8 bottom-8 w-px bg-outline-variant/30 hidden md:block"></div>

    <div class="flex flex-col gap-lg">
      {ab.timeline.steps.map((step: any, i: number) => (
        <ScrollReveal delay={i * 150} stagger>
          <div class="relative flex flex-col md:flex-row md:items-start gap-md md:gap-lg">
            <div class="flex items-center gap-md md:flex-col md:items-center md:w-48 md:shrink-0">
              <div class="relative z-10 flex items-center justify-center w-12 h-12 rounded-full bg-surface-container-lowest border-2 border-vue-green/40 font-label-mono text-label-mono text-vue-green shadow-lg shrink-0">
                <span class="material-symbols-outlined text-xl">
                  {i === 0 ? 'code' : i === 1 ? 'database' : 'neurology'}
                </span>
                            </div>
              <span class="font-label-mono text-label-mono text-vue-green/70 tracking-wider uppercase whitespace-nowrap">{step.year}</span>
            </div>
            <GlassCard class="p-lg flex-1">
              <h3 class="font-headline-md text-headline-md text-on-surface mb-xs">{step.title}</h3>
              <p class="font-body-md text-body-md text-slate-text">{step.description}</p>
            </GlassCard>
          </div>
        </ScrollReveal>
      ))}
    </div>
  </div>
</Section>

<!-- ============================================================
  BLOQUE 4 — STATS (La Trayectoria en Números)
  4 métricas con valor + label, fondo bg-surface-container-lowest.
  ============================================================ -->
<Section class="bg-surface-container-lowest border-y border-outline-variant/10">
  <ScrollReveal>
    <h2 class="font-display-lg text-headline-lg mb-sm text-center">{ab.stats.title}</h2>
    <p class="font-body-lg text-body-lg text-slate-text max-w-2xl mx-auto text-center mb-xl">{ab.stats.subtitle}</p>
  </ScrollReveal>
  <div class="grid grid-cols-2 md:grid-cols-4 gap-lg">
    {ab.stats.items.map((item: any, i: number) => (
      <ScrollReveal delay={i * 100} stagger>
        <StatCard value={item.value} label={item.label} />
      </ScrollReveal>
    ))}
  </div>
</Section>

<style>
  .material-symbols-outlined {
    font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
  }
  .stagger-header > * {
    opacity: 0;
    animation: fadeUp 0.6s ease forwards;
  }
  .stagger-header > :nth-child(1) { animation-delay: 0.1s; }
  .stagger-header > :nth-child(2) { animation-delay: 0.25s; }
  .stagger-header > :nth-child(3) { animation-delay: 0.4s; }
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
  }
</style>
