---
import Section from '../components/Section.astro'
import ScrollReveal from '../components/ScrollReveal.astro'
import PortfolioCard from '../components/PortfolioCard.astro'
import StatCard from '../components/StatCard.astro'
import { IMAGES, getResponsiveAttrs } from '../utils/images'
import { LOGOS } from '../utils/logos'

export interface Props {
  dict: Record<string, unknown>
  locale?: string
}

const { dict, locale = 'es' } = Astro.props
const pj = dict.projects_page as any
const imageLookup = IMAGES as Record<string, string | undefined>

/**
 * Section 2: Stack Grid — color lookups
 * Map pj.stack_grid keys to Tailwind v4 color tokens.
 * Keys match the JSON keys in i18n/*.json → stack_grid.
 * Icons via LOGOS record (src/utils/logos.ts) using local SVG sprite.
 * Mods: add/remove entries to match new JSON keys.
 */
const stackColors: Record<string, string> = {
  vue: 'electric-blue',
  node: 'electric-blue',
  typescript: 'blue-400',
  postgres: 'indigo-400',
  electron: 'cyan-400',
  salesforce: 'electric-blue',
  dotnet: 'electric-blue',
  linux: 'orange-400'
}
---

<!-- ===== SECTION 1: HERO ===== --><!-- Badge, title, description from i18n → pj.hero.{badge,title,description}.
     First section after nav — keep !pt-32 md:!pt-40. No bg class (default). -->
<Section class="!pt-32 md:!pt-40 !pb-lg md:!pb-xl">
  <div class="flex flex-col gap-base stagger-header">
    <div
      class="inline-flex items-center gap-sm bg-surface-charcoal/50 border border-electric-blue/30 w-fit px-4 py-1.5 rounded-full"
    >
      <span class="w-2 h-2 rounded-full bg-electric-blue animate-pulse"></span>
      <span class="font-label-mono text-label-mono text-electric-blue tracking-wider uppercase"
        >{pj.hero.badge}</span
      >
    </div>
    <h1
      class="font-display-lg text-headline-lg-mobile md:text-headline-lg text-on-surface max-w-4xl"
    >
      {pj.hero.title}
    </h1>
    <p class="font-body-lg text-body-lg max-sm:text-body-md text-slate-text max-w-3xl">
      {pj.hero.description}
    </p>
  </div>
</Section>

<!-- ===== SECTION 2: STACK GRID ===== -->
<!-- 12-col responsive grid. Iterates pj.stack_grid entries.
     - index 0: featured card (8 cols, 2 rows).
     - entries with label/title/desc: small cards (4 cols).
      - key='additional_tech': chip-list card (4 cols) aligned with .NET and Linux.
     Colors from stackColors record (match JSON keys). Icons from LOGOS (simpleicons.org).
     Hover border + box-shadow glow via data-color attr + bottom script.
     Background: bg-surface-container-lowest. -->
<Section class="bg-surface-container-lowest">
  <ScrollReveal>
    <div class="grid grid-cols-1 md:grid-cols-12 gap-md max-sm:auto-rows-auto auto-rows-[200px] md:auto-rows-[240px]">
      {
        Object.entries(pj.stack_grid).map(([key, tech]: [string, any], i: number) => {
          if (key === 'additional_tech') {
            return (
              <div class="md:col-span-4 bg-surface-charcoal border border-outline-variant/30 rounded-xl overflow-hidden p-md flex flex-col justify-between group relative tech-hover-card"
                data-color="var(--color-electric-blue)"
              >
                <div class="pointer-events-none absolute -inset-px rounded-xl opacity-0 transition-opacity duration-300 z-0"
                  style="background: radial-gradient(500px circle at var(--mouse-x, 50%) var(--mouse-y, 50%), rgba(0,168,255,0.15), transparent 60%)"
                  data-grid-glow
                />
                <div class="relative z-10">
                  <div class="flex justify-between items-start mb-sm">
                    <svg class="w-8 h-8" role="img" aria-label="additional">
                      <use href={LOGOS.vue} />
                    </svg>
                    <span class="font-label-mono text-[10px] px-2 py-0.5 rounded border/30"
                      style={{
                        color: 'var(--color-electric-blue)',
                        borderColor: 'color-mix(in srgb, var(--color-electric-blue) 30%, transparent)',
                        backgroundColor: 'color-mix(in srgb, var(--color-electric-blue) 10%, transparent)'
                      }}
                    >
                      COMPATIBLE
                    </span>
                  </div>
                  <h3 class="font-headline-md text-headline-md text-on-surface mb-xs">{tech.title}</h3>
                  <p class="font-body-md text-body-md text-slate-text mb-md">{tech.subtitle}</p>
                  <div class="flex flex-wrap gap-sm">
                    {tech.tags.map((item: string) => (
                      <span class="font-label-mono text-label-mono text-electric-blue bg-electric-blue/10 border border-electric-blue/20 px-3 py-1 rounded-full">
                        {item}
                      </span>
                    ))}
                  </div>
                </div>
              </div>
            )
          }
          return (
            <div
              class:list={[
                'group bg-surface-charcoal border border-outline-variant/30 rounded-xl transition-all duration-300 overflow-hidden relative tech-hover-card',
                i === 0
                  ? 'md:col-span-8 md:row-span-2 p-md md:p-lg flex flex-col justify-between'
                  : 'md:col-span-4 p-md flex flex-col justify-between'
              ]}
              data-color={`var(--color-${stackColors[key] || 'electric-blue'})`}
            >
              {i === 0 && (
                <>
                  <div
                    class="absolute -inset-px rounded-xl opacity-0 transition-opacity duration-300 pointer-events-none z-0"
                    style="background: radial-gradient(500px circle at var(--mouse-x, 50%) var(--mouse-y, 50%), rgba(0,168,255,0.15), transparent 60%)"
                    data-grid-glow
                  />
                  <div class="flex justify-between items-start">
                    <svg class="w-8 h-8" role="img" aria-label={key}>
                      <use href={LOGOS[key] || LOGOS.vue} />
                    </svg>
                    <span
                      class="font-label-mono text-[10px] px-2 py-0.5 rounded border/30 metric-glow"
                      style={{
                        color: `var(--color-${stackColors[key] || 'electric-blue'})`,
                        borderColor: `color-mix(in srgb, var(--color-${stackColors[key] || 'electric-blue'}) 30%, transparent)`,
                        backgroundColor: `color-mix(in srgb, var(--color-${stackColors[key] || 'electric-blue'}) 10%, transparent)`
                      }}
                    >
                      {tech.label}
                    </span>
                  </div>
                  <div class="relative z-10">
                    <h3 class="font-headline-lg text-headline-lg mb-sm">{tech.title}</h3>
                    <p class="font-body-md text-body-md text-slate-text">{tech.desc}</p>
                  </div>
                  {tech.tags && (
                    <div class="flex flex-wrap gap-1">
                      {tech.tags.map((tag: string) => (
                        <span class="font-label-mono text-label-mono text-electric-blue bg-electric-blue/10 border border-electric-blue/20 px-3 py-1 rounded-full">
                          {tag}
                        </span>
                      ))}
                    </div>
                  )}
                  <div class="absolute inset-0 bg-gradient-to-t from-electric-blue/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none" />
                </>
              )}
              {i !== 0 && (
                <>
                  <div
                    class="absolute -inset-px rounded-xl opacity-0 transition-opacity duration-300 pointer-events-none z-0"
                    style="background: radial-gradient(500px circle at var(--mouse-x, 50%) var(--mouse-y, 50%), rgba(0,168,255,0.15), transparent 60%)"
                    data-grid-glow
                  />
                  <div class="flex justify-between items-start">
                    <svg class="w-8 h-8" role="img" aria-label={key}>
                      <use href={LOGOS[key] || LOGOS.vue} />
                    </svg>
                    <span
                      class="font-label-mono text-[10px] px-2 py-0.5 rounded border/30 metric-glow"
                      style={{
                        color: `var(--color-${stackColors[key] || 'electric-blue'})`,
                        borderColor: `color-mix(in srgb, var(--color-${stackColors[key] || 'electric-blue'}) 30%, transparent)`,
                        backgroundColor: `color-mix(in srgb, var(--color-${stackColors[key] || 'electric-blue'}) 10%, transparent)`
                      }}
                    >
                      {tech.label}
                    </span>
                  </div>
                  <div>
                    <h4 class="font-headline-md text-headline-md mb-xs">{tech.title}</h4>
                    <p class="text-sm text-slate-text">{tech.desc}</p>
                  </div>
                  {tech.tags && (
                    <div class="flex flex-wrap gap-1 mt-1">
                      {tech.tags.map((tag: string) => (
                        <span class="font-label-mono text-label-mono text-electric-blue bg-electric-blue/10 border border-electric-blue/20 px-3 py-1 rounded-full">
                          {tag}
                        </span>
                      ))}
                    </div>
                  )}
                </>
              )}
            </div>
          )
        })
      }
    </div>
  </ScrollReveal>
</Section>

<!-- ===== SECTION 3: PORTFOLIO ===== -->
<!-- Header (title + subtitle + view_all link) + 3-card grid.
     Cards from pj.portfolio.cards[] array. Each card shape: { tag, title, desc }.
     Images from IMAGES constant (src/utils/images.ts) — indexed by position.
     Staggered ScrollReveal with i*100 delay.
     Background: bg-surface-container-low. -->
<Section class="bg-surface-container-low">
  <ScrollReveal>
    <div class="flex flex-col md:flex-row justify-between items-end max-sm:mb-md mb-lg gap-md">
      <div>
        <h2 class="font-display-lg text-headline-lg text-on-surface mb-xs">{pj.portfolio.title}</h2>
        <p class="font-body-md text-body-md text-slate-text">{pj.portfolio.subtitle}</p>
      </div>
      <!-- <a class="group flex items-center gap-xs text-electric-blue font-label-mono" href="#">
        {pj.portfolio.view_all}
        <Icon name="arrow_forward" class="transition-transform group-hover:translate-x-1" />
      </a> -->
    </div>
  </ScrollReveal>
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-md">
    {
      pj.portfolio.cards.map((card: any, i: number) => {
        const image = imageLookup[card.image_key]
        const responsive = getResponsiveAttrs(card.image_key)
        return (
          <ScrollReveal delay={i * 100} stagger>
            <PortfolioCard
              tag={card.tag}
              title={card.title}
              description={card.desc}
              image={image}
              srcset={responsive?.srcset}
              sizes={responsive?.sizes}
              slug={card.slug}
              locale={locale}
              imageKey={card.image_key}
            />
          </ScrollReveal>
        )
      })
    }
  </div>
</Section>

<!-- ===== SECTION 4: STATS ===== -->
<!-- 4 metric cards with value + label. Data: pj.stats.stat_{1..4}.{value,label}.
     Background: bg-surface-container-lowest + top border. -->
<Section class="bg-surface-container-lowest border-t border-outline-variant/10">
  <ScrollReveal>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-lg">
      <StatCard value={pj.stats.stat_1.value} label={pj.stats.stat_1.label} />
      <StatCard value={pj.stats.stat_2.value} label={pj.stats.stat_2.label} />
      <StatCard value={pj.stats.stat_3.value} label={pj.stats.stat_3.label} />
      <StatCard value={pj.stats.stat_4.value} label={pj.stats.stat_4.label} />
    </div>
  </ScrollReveal>
</Section>

<!-- ===== STYLES: Section-level. Component styles in their own .astro files. ===== -->
<style>
.tech-hover-card {
    transition: border-color 0.3s ease;
    box-shadow: 0 0 14px color-mix(in srgb, var(--color-electric-blue) 10%, transparent);
  }
</style>

<!-- ===== CLIENT-SIDE SCRIPT: Stack Grid hover border ===== -->
<!-- Reads data-color from each .tech-hover-card and applies it as borderColor on hover.
     data-color matches the stackColors record (e.g. 'var(--color-electric-blue)').
     Only runs on the stack grid section. -->
<script>
  let rafId = 0
  let pendingCard: HTMLElement | null = null
  let pendingX = 0
  let pendingY = 0

  function flushGrid() {
    rafId = 0
    if (!pendingCard) return
    const rect = pendingCard.getBoundingClientRect()
    pendingCard.style.setProperty('--mouse-x', `${((pendingX - rect.left) / rect.width) * 100}%`)
    pendingCard.style.setProperty('--mouse-y', `${((pendingY - rect.top) / rect.height) * 100}%`)
    pendingCard = null
  }

  ;(document.querySelectorAll('.tech-hover-card') as NodeListOf<HTMLElement>).forEach((card) => {
    const color = card.getAttribute('data-color')
    const glow = card.querySelector('[data-grid-glow]') as HTMLElement
    if (!color) return
    card.addEventListener('mouseenter', () => {
      card.style.borderColor = color
      card.style.boxShadow = `0 0 28px color-mix(in srgb, ${color} 30%, transparent)`
      if (glow) glow.style.opacity = '1'
    })
    card.addEventListener('mousemove', (e: MouseEvent) => {
      pendingCard = card
      pendingX = e.clientX
      pendingY = e.clientY
      if (!rafId) rafId = requestAnimationFrame(flushGrid)
    })
    card.addEventListener('mouseleave', () => {
      card.style.borderColor = ''
      card.style.boxShadow = ''
      if (glow) glow.style.opacity = '0'
    })
  })
</script>
