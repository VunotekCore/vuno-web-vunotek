---
import Section from '../components/Section.astro'
import GlassCard from '../components/GlassCard.astro'
import Button from '../components/Button.astro'
import ServicesTechnical from '../components/ServicesTechnical.astro'
import ScrollReveal from '../components/ScrollReveal.astro'
import ProcessIndicator from '../components/ProcessIndicator.astro'
import Icon from '../components/Icon.astro';

export interface Props {
  dict: Record<string, unknown>
  locale: string
}

const { dict, locale } = Astro.props
const svp = dict.services_page as any
const p = (path: string) => (locale === 'en' ? `/en${path}` : path)
---

<!-- ============================================================
  SECTION 1 — HERO / DOCUMENTATION HEADER
  Muestra: tag (// core_capabilities.json), título con acento
  gradient, descripción principal.
  Datos: svp.hero, svp.meta.section_tag
  Posición: primer bloque visible, fondo por defecto.
  NOTA: pt-20/pt-24 matchea padding superior del Hero (Home page).
  ============================================================ -->
<Section class="!pt-32 md:!pt-40 !pb-lg md:!pb-xl">
  <div class="flex flex-col gap-base stagger-header">
    <div class="inline-flex items-center gap-sm bg-surface-charcoal/50 border border-electric-blue/30 w-fit px-4 py-1.5 rounded-full">
      <span class="w-2 h-2 rounded-full bg-electric-blue animate-pulse"></span>
      <span class="font-label-mono text-label-mono text-electric-blue tracking-wider uppercase">{svp.meta.section_tag}</span>
    </div>
    <h1 class="font-display-lg text-headline-lg-mobile md:text-headline-lg text-on-surface max-w-4xl">
      {svp.hero.title}<br />
      <span class="bg-gradient-to-r from-electric-blue to-sky-400 bg-clip-text text-transparent">{svp.hero.titleAccent}</span> {svp.hero.titleRest}
    </h1>
    <p class="font-body-lg text-body-lg max-sm:text-body-md text-slate-text max-w-3xl">
      {svp.hero.description}
    </p>
  </div>
</Section>



<!-- ============================================================
  SECTION 2 — CORE SERVICES TABLE
  Tabla técnica con 4 servicios: Backend, Salesforce, Web,
  Desktop. Cada uno con icono, descripción, tecnologías.
  Datos: svp.core_services[]
  CTA: enlace a /proyectos
  ============================================================ -->
<Section class="bg-surface-container-lowest border-y border-outline-variant/10">
  <ScrollReveal>
    <ServicesTechnical
      items={svp.core_services}
      ctaLabel={locale === 'en' ? 'View platforms built with this stack →' : 'Ver plataformas construidas con este stack →'}
      ctaHref={p('/proyectos')}
    />
  </ScrollReveal>
</Section>

<!-- ============================================================
  SECTION 3 — EXECUTION PROTOCOL
  Timeline de 3 pasos (Analizar → Diseñar → Desplegar).
  Datos: svp.process, svp.process.steps[]
  ============================================================ -->
<Section class="!py-base md:!py-lg">
  <ProcessIndicator title={svp.process.title} steps={svp.process.steps} />
</Section>

<!-- ============================================================
  SECTION 4 — FINAL CTA
  GlassCard con título, descripción, 2 botones:
    - Principal → /contacto (Agendar Auditoría Técnica)
    - Secundario → /proyectos (Ver Nuestro Stack)
  Datos: svp.cta
  ============================================================ -->
<Section class="bg-surface-container-lowest border-y border-outline-variant/10">
  <ScrollReveal>
    <GlassCard class="p-xl text-center relative overflow-hidden">
      <div class="relative z-10 flex flex-col gap-base items-center">
        <h2 class="font-display-lg text-headline-lg text-on-surface">{svp.cta.title}</h2>
        <p class="font-body-lg text-body-lg text-slate-text max-w-2xl">{svp.cta.desc}</p>
        <div class="flex flex-col sm:flex-row gap-md justify-center pt-sm">
          <Button href={p('/contacto')} size="lg" title={svp.cta.button}>
            <Icon name="forum" class="text-2xl" />
            <span class="sm:inline hidden">{svp.cta.button}</span>
          </Button>
          <Button variant="secondary" href={p('/proyectos')} size="lg" title={svp.cta.buttonSecondary}>
            <Icon name="layers" class="text-2xl" />
            <span class="sm:inline hidden">{svp.cta.buttonSecondary}</span>
          </Button>
        </div>
      </div>
    </GlassCard>
  </ScrollReveal>
</Section>
