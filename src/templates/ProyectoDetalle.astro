---
import Section from '../components/Section.astro'
import GlassCard from '../components/GlassCard.astro'
import ScrollReveal from '../components/ScrollReveal.astro'
import Button from '../components/Button.astro'
import { IMAGES, IMAGE_DIMS, getResponsiveAttrs } from '../utils/images'
import Icon from '../components/Icon.astro';
import { getImageAlt } from '../seo';

export interface Props {
  card: {
    tag: string
    title: string
    desc: string
    image_key: string
    features: { text: string; image: string }[]
    tech_stack: string[]
  }
  locale?: string
}

const { card, locale = 'es' } = Astro.props
const backUrl = locale === 'en' ? '/en/proyectos' : '/proyectos'
const contactUrl = locale === 'en' ? '/en/contacto' : '/contacto'
const imageKey = card.image_key
const image = (IMAGES as Record<string, string>)[imageKey] || undefined
const imgDims = (IMAGE_DIMS as Record<string, { width: number; height: number }>)[imageKey]
const imgResponsive = getResponsiveAttrs(imageKey)
const isPlaceholder = !image

const imageStore = IMAGES as Record<string, string>

function resolveImage(key: string): string {
  if (imageStore[key]) return imageStore[key]
  const label = key
    .split('-')
    .slice(1)
    .join(' ')
    .replace(/\b\w/g, (c) => c.toUpperCase())
  return `https://placehold.co/800x600/1e293b/42b883?text=${encodeURIComponent(label)}`
}

const techIcons: Record<string, string> = {
  TypeScript: 'javascript',
  'Vue.js': 'view_quilt',
  'Node.js': 'terminal',
  Electron: 'desktop_windows',
  Astro: 'rocket_launch',
  Stripe: 'payments',
  PHP: 'code',
  'Tailwind CSS': 'palette',
  PWA: 'install_mobile',
  'SQL Server': 'storage',
  IndexedDB: 'database',
  PostgreSQL: 'storage',
  WebSocket: 'wifi',
}
---

<section class="relative overflow-hidden !pt-32 md:!pt-40 pb-lg md:pb-xl px-margin" style="scroll-margin-top: 80px;">
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
    <div class="absolute inset-0" style="background-image: radial-gradient(rgba(0,168,255,0.06) 1px, transparent 1px); background-size: 32px 32px;"></div>
  </div>

  <div class="max-w-[min(90vw,1600px)] mx-auto relative">
    <a href={backUrl} class="inline-flex items-center gap-xs text-electric-blue font-label-mono hover:underline mb-lg">
      <Icon name="arrow_back" class="text-sm" />
      {locale === 'en' ? 'Back to projects' : 'Volver a proyectos'}
    </a>

    <div class="flex flex-col gap-base stagger-header">
      <div class="inline-flex items-center gap-sm bg-surface-charcoal/50 border border-electric-blue/30 w-fit px-4 py-1.5 rounded-full">
        <span class="w-2 h-2 rounded-full bg-electric-blue animate-pulse" />
        <span class="font-label-mono text-label-mono text-electric-blue tracking-wider uppercase">{card.tag}</span>
      </div>

      <h1 class="font-display-lg text-headline-lg-mobile md:text-headline-lg text-on-surface max-w-4xl">
        {card.title}
      </h1>

      <p class="font-body-lg text-body-lg text-slate-text max-w-3xl">
        {card.desc}
      </p>
    </div>
  </div>
</section>

{image && !isPlaceholder && (
  <Section class="!pt-0 !pb-lg md:!pb-xl">
      <div class="relative overflow-hidden rounded-xl border border-outline-variant/30 max-w-5xl mx-auto group cursor-pointer" data-lightbox>
      <div class="aspect-[4/3] bg-surface-charcoal overflow-hidden">
        <img
          src={image}
          alt={getImageAlt(locale, imageKey)}
          width={imgDims?.width || 800}
          height={imgDims?.height || 600}
          loading="eager"
          decoding="async"
          fetchpriority="high"
          srcset={imgResponsive?.srcset}
          sizes={imgResponsive?.sizes}
          class="w-full h-full object-contain transition-all duration-700 group-hover:scale-[1.03]"
        />
      </div>
      <div class="absolute inset-0 ring-1 ring-inset ring-electric-blue/20 rounded-xl opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none" />
      <div class="absolute bottom-3 right-3 bg-surface-charcoal/80 backdrop-blur-sm rounded-lg px-3 py-1.5 opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none flex items-center gap-1.5">
        <Icon name="zoom_out_map" class="text-slate-text text-sm" />
        <span class="font-label-mono text-label-mono text-slate-text/80 text-xs">{locale === 'en' ? 'Expand' : 'Ampliar'}</span>
      </div>
      <div class="absolute bottom-0 left-0 right-0 h-24 bg-gradient-to-t from-surface-dim/60 to-transparent pointer-events-none" />
    </div>
  </Section>
)}

{isPlaceholder && (
  <Section class="!pt-0 !pb-lg md:!pb-xl">
      <div class="relative overflow-hidden rounded-xl border border-outline-variant/30 max-w-5xl mx-auto aspect-[4/3] bg-surface-charcoal flex items-center justify-center">
      <div class="absolute inset-0" style="background-image: radial-gradient(rgba(0,168,255,0.06) 1px, transparent 1px); background-size: 24px 24px;"></div>
      <div class="flex flex-col items-center gap-sm relative z-10">
        <div class="w-20 h-20 rounded-2xl bg-electric-blue/10 border border-electric-blue/30 flex items-center justify-center">
          <Icon name="grid_view" class="text-4xl text-electric-blue" />
        </div>
        <span class="font-label-mono text-label-mono text-slate-text/60 uppercase">{card.tag}</span>
        <span class="font-body-sm text-body-sm text-slate-text/40">{locale === 'en' ? 'Preview coming soon' : 'Vista previa próximamente'}</span>
      </div>
    </div>
  </Section>
)}

<Section class="bg-surface-container-lowest">
  <ScrollReveal>
    <h2 class="font-display-lg text-headline-lg text-on-surface mb-xl">
      {locale === 'en' ? 'Key Features' : 'Características Principales'}
    </h2>
  </ScrollReveal>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-md">
    {card.features.map((feature, index) => (
      <ScrollReveal delay={index * 80}>
        <GlassCard class="group cursor-pointer" data-lightbox-feature>
          <div class="h-44 overflow-hidden bg-surface-charcoal rounded-t-xl relative">
            <img
              src={resolveImage(feature.image)}
              alt={getImageAlt(locale, imageKey, feature.image)}
              width="800"
              height="600"
              class="w-full h-full object-cover transition-all duration-500 group-hover:scale-[1.04]"
              loading="lazy"
              decoding="async"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-surface-charcoal/40 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300" />
            <div class="absolute inset-0 ring-1 ring-inset ring-electric-blue/20 rounded-t-xl opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none" />
            <div class="absolute top-3 right-3 bg-surface-charcoal/70 backdrop-blur-sm rounded-full w-8 h-8 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none">
              <Icon name="zoom_out_map" class="text-slate-text text-sm" />
            </div>
          </div>
          <div class="p-md">
            <div class="flex items-start gap-md">
              <Icon name="check_circle" class="text-electric-blue text-xl mt-0.5 shrink-0" />
              <p class="font-body-md text-body-md text-slate-text">{feature.text}</p>
            </div>
          </div>
        </GlassCard>
      </ScrollReveal>
    ))}
  </div>
</Section>

{card.tech_stack && card.tech_stack.length > 0 && (
  <Section>
    <ScrollReveal>
      <h2 class="font-display-lg text-headline-lg text-on-surface mb-lg">
        {locale === 'en' ? 'Tech Stack' : 'Stack Tecnológico'}
      </h2>
    </ScrollReveal>

    <div class="flex flex-wrap gap-sm">
      {card.tech_stack.map((tech) => (
        <ScrollReveal>
          <div class="inline-flex items-center gap-base bg-surface-charcoal border border-outline-variant/30 rounded-full px-5 py-2.5 transition-all duration-300 hover:border-electric-blue/50 hover:bg-electric-blue/5 hover:shadow-[0_0_16px_rgba(0,168,255,0.12)]">
            <Icon name={techIcons[tech] || 'code'} class="text-electric-blue text-lg" />
            <span class="font-label-mono text-label-mono text-slate-text">{tech}</span>
          </div>
        </ScrollReveal>
      ))}
    </div>
  </Section>
)}

<Section class="bg-surface-container-lowest border-y border-outline-variant/10">
  <div class="glass-panel rounded-xl p-lg md:p-xl border border-outline-variant/30">
    <div class="flex flex-col md:flex-row items-start md:items-center justify-between gap-lg">
      <div class="max-w-2xl">
        <h3 class="font-display-lg text-headline-lg-mobile md:text-headline-lg text-on-surface mb-sm">
          {locale === 'en' ? 'Interested in this solution?' : '¿Te interesa esta solución?'}
        </h3>
        <p class="font-body-lg text-body-lg text-slate-text">
          {locale === 'en'
            ? 'Schedule a personalized demo and discover how VUNO can transform your business.'
            : 'Agenda una demo personalizada y descubre cómo VUNO puede transformar tu negocio.'}
        </p>
      </div>
      <Button href={contactUrl} variant="primary" size="lg">
        {locale === 'en' ? 'Request a Demo' : 'Solicitar Demo'}
      </Button>
    </div>
  </div>
</Section>

<script>
  function openLightbox(src: string, trigger: HTMLElement) {
    const overlay = document.createElement('div')
    overlay.setAttribute('role', 'dialog')
    overlay.setAttribute('aria-modal', 'true')
    overlay.setAttribute('aria-label', 'Image lightbox')
    overlay.style.cssText = 'position:fixed;inset:0;z-index:9999;background:rgba(0,0,0,0.92);display:flex;align-items:center;justify-content:center;cursor:zoom-out;animation:fadeIn 0.2s ease;'

    const img = document.createElement('img')
    img.src = src
    img.alt = trigger.querySelector('img')?.alt || 'Project image'
    img.style.cssText = 'max-width:92vw;max-height:92vh;object-fit:contain;border-radius:12px;box-shadow:0 0 60px rgba(0,0,0,0.5);'

    const closeBtn = document.createElement('button')
    closeBtn.innerHTML = 'close'
    closeBtn.setAttribute('aria-label', 'Close lightbox')
    closeBtn.style.cssText = 'position:absolute;top:24px;right:24px;background:rgba(255,255,255,0.1);border:none;color:#dae2fd;width:44px;height:44px;border-radius:50%;cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:24px;backdrop-filter:blur(8px);transition:background 0.2s;font-family:Material Symbols Outlined;'
    closeBtn.addEventListener('mouseenter', () => closeBtn.style.background = 'rgba(255,255,255,0.2)')
    closeBtn.addEventListener('mouseleave', () => closeBtn.style.background = 'rgba(255,255,255,0.1)')

    overlay.appendChild(img)
    overlay.appendChild(closeBtn)
    document.body.appendChild(overlay)
    closeBtn.focus()

    const close = () => { overlay.remove(); trigger.focus() }
    overlay.addEventListener('click', (e) => { if (e.target === overlay || e.target === img) close() })
    closeBtn.addEventListener('click', close)
    overlay.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') { close(); return }
      if (e.key === 'Tab') { e.preventDefault(); closeBtn.focus() }
    })
  }

  document.addEventListener('click', (e) => {
    const target = e.target as HTMLElement
    const lightbox = target.closest('[data-lightbox]') as HTMLElement | null
    if (lightbox) {
      const img = lightbox.querySelector('img')
      if (img?.src) openLightbox(img.src, lightbox)
      return
    }
    const feature = target.closest('[data-lightbox-feature]') as HTMLElement | null
    if (feature) {
      const img = feature.querySelector('img')
      if (img?.src) openLightbox(img.src, feature)
    }
  })
</script>

<style>
  @keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }
</style>
